<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="external_layout_company_name_fix"
              inherit_id="web.external_layout"
              priority="100">

        <!-- Reemplazar el nombre de la empresa para evitar commercial_partner_id -->
        <xpath expr="//span[@t-field='company.partner_id.commercial_company_name']"
               position="replace">
            <span t-out="company.name"/>
        </xpath>

    </template>

</odoo>
