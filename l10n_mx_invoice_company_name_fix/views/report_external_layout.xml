<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="external_layout_company_name_fix"
              inherit_id="web.external_layout"
              priority="100">

        <!-- Reemplazar bloque completo del nombre de la empresa -->
        <xpath expr="//t[@t-if='company.partner_id']" position="replace">
            <t t-if="company">
                <span t-out="company.name"/>
            </t>
        </xpath>

    </template>

</odoo>
