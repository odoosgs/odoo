<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="external_layout_company_name_fix"
              inherit_id="web.external_layout"
              priority="100">

        <!-- Forzamos el company antes de que el layout renderice -->
        <xpath expr="." position="inside">
            <t t-set="company"
               t-value="company.with_context(
                   force_report_company_name=company.name
               )"/>
        </xpath>

    </template>

</odoo>
