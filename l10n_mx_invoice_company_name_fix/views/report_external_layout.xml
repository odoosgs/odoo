<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="external_layout_company_name_fix"
              inherit_id="web.external_layout"
              priority="100">

        <!-- Sobrescribimos el nombre legal de la empresa ANTES de render -->
        <xpath expr="." position="inside">
            <t t-set="company"
               t-value="company.with_context(force_company_name=True)"/>
        </xpath>

    </template>

</odoo>
