<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Kanban de Custodios -->
    <record id="view_sgs_custodian_kanban" model="ir.ui.view">
        <field name="name">sgs.custodian.kanban</field>
        <field name="model">sgs.custodian</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="employee_number"/>
                <field name="balance"/>
                <field name="total_expenses"/>
                <field name="compliance_state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click sgs-kanban-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong><field name="name"/></strong><br/>
                                    <span class="text-muted"><field name="employee_number"/> · <field name="position"/></span>
                                </div>
                                <span t-attf-class="badge rounded-pill #{record.compliance_state.raw_value == 'green' and 'text-bg-success' or record.compliance_state.raw_value == 'yellow' and 'text-bg-warning' or record.compliance_state.raw_value == 'red' and 'text-bg-danger' or 'text-bg-info'}">
                                    <field name="compliance_state"/>
                                </span>
                            </div>
                            <div class="mt-3 d-flex justify-content-between">
                                <div><small>Saldo</small><br/><strong><field name="balance" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong></div>
                                <div><small>Gastos</small><br/><strong><field name="total_expenses" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista de Lista Moderna de Custodios -->
    <record id="view_sgs_custodian_list" model="ir.ui.view">
        <field name="name">sgs.custodian.list</field>
        <field name="model">sgs.custodian</field>
        <field name="arch" type="xml">
            <list decoration-danger="balance &lt; 0" decoration-warning="pending_service_count &gt; 0" decoration-success="compliance_state == 'green'">
                <field name="employee_number"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="position"/>
                <field name="phone"/>
                <field name="initial_fund" sum="Fondo"/>
                <field name="total_deposits" sum="Depósitos"/>
                <field name="total_expenses" sum="Gastos"/>
                <field name="balance" sum="Saldo"/>
                <field name="compliance_state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Formulario Completo de Custodios - Conexión con Empleado Odoo 19 -->
    <record id="view_sgs_custodian_form" model="ir.ui.view">
        <field name="name">sgs.custodian.form</field>
        <field name="model">sgs.custodian</field>
        <field name="arch" type="xml">
            <form string="Custodio">
                <header>
                    <button name="action_open_portal" type="object" string="Abrir portal" class="btn-primary"/>
                    <button name="action_regenerate_portal_token" type="object" string="Regenerar token" class="btn-secondary" confirm="El enlace anterior dejará de funcionar. ¿Continuar?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre completo del custodio"/></h1>
                    </div>
                    <group>
                        <group string="Vinculación de Personal">
                            <!-- NUEVO CAMPO: Relación al modelo de empleados oficial hr.employee -->
                            <field name="employee_id" placeholder="Vincular con empleado oficial..."/>
                            <field name="employee_number"/>
                            <field name="position"/>
                            <field name="phone"/>
                            <field name="initial_fund"/>
                        </group>
                        <group string="Resumen Financiero">
                            <field name="total_deposits" readonly="1"/>
                            <field name="total_expenses" readonly="1"/>
                            <field name="total_fiscal" readonly="1"/>
                            <field name="balance" readonly="1"/>
                            <field name="compliance_state" readonly="1" widget="badge"/>
                        </group>
                    </group>
                    <group string="Portal Público">
                        <field name="portal_url" readonly="1" widget="url"/>
                        <field name="whatsapp_url" readonly="1" widget="url"/>
                    </group>
                    <notebook>
                        <page string="Depósitos">
                            <field name="deposit_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="week"/>
                                    <field name="concept"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Servicios">
                            <field name="service_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="client_id"/>
                                    <field name="origin"/>
                                    <field name="destination"/>
                                    <field name="amount_total"/>
                                    <field name="status" widget="badge"/>
                                    <field name="is_late"/>
                                </list>
                            </field>
                        </page>
                        <page string="Comprobantes fiscales">
                            <field name="fiscal_receipt_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="provider"/>
                                    <field name="provider_vat"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Listado de Servicios de Ruta -->
    <record id="view_sgs_service_list" model="ir.ui.view">
        <field name="name">sgs.route.service.list</field>
        <field name="model">sgs.route.service</field>
        <field name="arch" type="xml">
            <list decoration-danger="status == 'rejected' or is_late" decoration-warning="status == 'pending'" decoration-success="status == 'approved'">
                <field name="name"/>
                <field name="date"/>
                <field name="custodian_id"/>
                <field name="client_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="vehicle_snapshot"/>
                <field name="amount_total" sum="Total"/>
                <field name="status" widget="badge"/>
                <field name="is_late"/>
            </list>
        </field>
    </record>

    <!-- Formulario de Pedido / Ruta de Custodia -->
    <record id="view_sgs_service_form" model="ir.ui.view">
        <field name="name">sgs.route.service.form</field>
        <field name="model">sgs.route.service</field>
        <field name="arch" type="xml">
            <form string="Servicio / Gasto">
                <header>
                    <button name="action_approve" type="object" string="Autorizar" class="btn-primary" invisible="status == 'approved'"/>
                    <button name="action_reject" type="object" string="Rechazar" class="btn-secondary" invisible="status == 'rejected'"/>
                    <button name="action_pending" type="object" string="Marcar pendiente" invisible="status == 'pending'"/>
                    <field name="status" widget="statusbar" statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Planificación">
                            <field name="custodian_id"/>
                            <field name="date"/>
                            <field name="submit_datetime"/>
                            <field name="is_late"/>
                            <field name="client_id"/>
                        </group>
                        <group string="Vehículo y Custodias">
                            <field name="origin" placeholder="Ej: Guadalajara"/>
                            <field name="destination" placeholder="Ej: Nuevo Laredo"/>
                            <field name="companion" placeholder="Custodios a bordo o unidad"/>
                            <field name="vehicle_id"/>
                            <field name="vehicle_snapshot"/>
                            <field name="plate_snapshot"/>
                        </group>
                    </group>
                    <group string="Desglose de Gastos">
                        <group>
                            <field name="amount_perdiem"/>
                            <field name="amount_fuel"/>
                            <field name="amount_lodging"/>
                            <field name="amount_misc"/>
                            <field name="misc_detail" placeholder="Obligatorio si existe gasto vario"/>
                        </group>
                        <group>
                            <field name="amount_tolls" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="evidence_image" widget="image" filename="evidence_filename"/>
                            <field name="evidence_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Casetas">
                            <field name="toll_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="amount"/>
                                    <field name="image" widget="image" filename="image_filename"/>
                                    <field name="image_filename" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Comentarios">
                            <field name="comments"/>
                            <field name="validation_note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>