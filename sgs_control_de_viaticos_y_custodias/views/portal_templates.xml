<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_custodian_home" name="Portal custodio SGS">
        <t t-call="portal.portal_layout">
            <div class="sgs-portal" style="padding: 20px; font-family: sans-serif;">
                <div class="sgs-overline" style="text-transform: uppercase; color: #7c3aed; font-size: 11px; font-weight: bold; letter-spacing: 1px;">SGS · Control de Viáticos</div>
                <h1 style="font-size: 28px; margin-top: 5px; color: #111827;"><t t-esc="custodian.name"/></h1>
                <p style="color: #6b7280; margin-bottom: 30px;"><t t-esc="custodian.employee_number or 'S/N'"/> · <t t-esc="custodian.position or 'Custodio Movil'"/></p>

                <!-- Resumen de Saldos -->
                <div style="background: #fdfdfd; border: 1px solid #e5e7eb; padding: 20px; border-radius: 12px; margin-bottom: 25px;">
                    <span style="font-size: 12px; color: #6b7280; text-transform: uppercase;">Saldo disponible para comprobación</span>
                    <h2 style="font-size: 32px; color: #10b981; margin: 5px 0 0 0;"><t t-esc="format_amount(custodian.balance, custodian.currency_id)"/></h2>
                </div>
            </div>
        </t>
    </template>
</odoo>