<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_sgs_custodian" model="ir.actions.act_window">
        <name>Custodios</name>
        <res_model>hr.employee</res_model>
        <view_mode>kanban,list,form</view_mode>
        <domain>[('portal_token', '!=', False)]</domain>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay custodios configurados.
            </p>
            <p>
                Los empleados con un Token de Portal generado aparecerán aquí.
            </p>
        </help>
    </record>

    <record id="action_sgs_perdiem_deposit" model="ir.actions.act_window">
        <name>Depósitos de Viáticos</name>
        <res_model>sgs.perdiem.deposit</res_model>
        <view_mode>list,form</view_mode>
    </record>

    <record id="action_sgs_route_service" model="ir.actions.act_window">
        <name>Servicios y Gastos</name>
        <res_model>sgs.route.service</res_model>
        <view_mode>list,form</view_mode>
    </record>

    <menuitem id="menu_sgs_root" name="SGS Custodia" web_icon="sgs_custody_perdiem,static/description/icon.png" sequence="10"/>

    <menuitem id="menu_sgs_operations" name="Operaciones" parent="menu_sgs_root" sequence="10"/>
    
    <menuitem id="menu_sgs_custodian" name="Custodios" parent="menu_sgs_operations" action="action_sgs_custodian" sequence="10"/>
    <menuitem id="menu_sgs_route_service" name="Servicios / Rutas" parent="menu_sgs_operations" action="action_sgs_route_service" sequence="20"/>
    <menuitem id="menu_sgs_perdiem_deposit" name="Depósitos" parent="menu_sgs_operations" action="action_sgs_perdiem_deposit" sequence="30"/>
</odoo>
