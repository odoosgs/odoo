<odoo>
    <record id="view_sgs_custodian_kanban" model="ir.ui.view">
        <field name="name">sgs.custodian.kanban</field>
        <field name="model">sgs.custodian</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/><field name="employee_number"/><field name="balance"/><field name="total_expenses"/><field name="compliance_state"/><field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click sgs-kanban-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong><field name="name"/></strong><br/>
                                    <span class="text-muted"><field name="employee_number"/> · <field name="position"/></span>
                                </div>
                                <span t-attf-class="badge rounded-pill #{record.compliance_state.raw_value == 'green' and 'text-bg-success' or record.compliance_state.raw_value == 'yellow' and 'text-bg-warning' or record.compliance_state.raw_value == 'red' and 'text-bg-danger' or 'text-bg-info'}">
                                    <field name="compliance_state"/>
                                </span>
                            </div>
                            <div class="mt-3 d-flex justify-content-between">
                                <div><small>Saldo</small><br/><strong><field name="balance" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong></div>
                                <div><small>Gastos</small><br/><strong><field name="total_expenses" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sgs_custodian_list" model="ir.ui.view">
        <field name="name">sgs.custodian.list</field>
        <field name="model">sgs.custodian</field>
        <field name="arch" type="xml">
            <list decoration-danger="balance &lt; 0" decoration-warning="pending_service_count &gt; 0" decoration-success="compliance_state == 'green'">
                <field name="employee_number"/>
                <field name="name"/>
                <field name="position"/>
                <field name="phone"/>
                <field name="initial_fund" sum="Fondo"/>
                <field name="total_deposits" sum="Depósitos"/>
                <field name="total_expenses" sum="Gastos"/>
                <field name="balance" sum="Saldo"/>
                <field name="pending_service_count"/>
                <field name="compliance_state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_sgs_custodian_form" model="ir.ui.view">
        <field name="name">sgs.custodian.form</field>
        <field name="model">sgs.custodian</field>
        <field name="arch" type="xml">
            <form string="Custodio">
                <header>
                    <button name="action_open_portal" type="object" string="Abrir portal" class="btn-primary"/>
                    <button name="action_regenerate_portal_token" type="object" string="Regenerar token" class="btn-secondary" confirm="El enlace anterior dejará de funcionar. ¿Continuar?"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="Nombre del custodio"/></h1></div>
                    <group>
                        <group>
                            <field name="employee_number"/>
                            <field name="position"/>
                            <field name="phone"/>
                            <field name="initial_fund"/>
                        </group>
                        <group>
                            <field name="total_deposits" readonly="1"/>
                            <field name="total_expenses" readonly="1"/>
                            <field name="total_fiscal" readonly="1"/>
                            <field name="balance" readonly="1"/>
                            <field name="compliance_state" readonly="1" widget="badge"/>
                        </group>
                    </group>
                    <group string="Portal público">
                        <field name="portal_url" readonly="1" widget="url"/>
                        <field name="whatsapp_url" readonly="1" widget="url"/>
                    </group>
                    <notebook>
                        <page string="Depósitos"><field name="deposit_ids"><list editable="bottom"><field name="date"/><field name="week"/><field name="concept"/><field name="amount"/></list></field></page>
                        <page string="Servicios"><field name="service_ids"><list><field name="name"/><field name="date"/><field name="client_id"/><field name="origin"/><field name="destination"/><field name="amount_total"/><field name="status" widget="badge"/><field name="is_late"/></list></field></page>
                        <page string="Comprobantes fiscales"><field name="fiscal_receipt_ids"><list editable="bottom"><field name="date"/><field name="description"/><field name="provider"/><field name="provider_vat"/><field name="amount"/></list></field></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sgs_service_list" model="ir.ui.view">
        <field name="name">sgs.route.service.list</field>
        <field name="model">sgs.route.service</field>
        <field name="arch" type="xml">
            <list decoration-danger="status == 'rejected' or is_late" decoration-warning="status == 'pending'" decoration-success="status == 'approved'">
                <field name="name"/>
                <field name="date"/>
                <field name="custodian_id"/>
                <field name="client_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="vehicle_snapshot"/>
                <field name="amount_total" sum="Total"/>
                <field name="status" widget="badge"/>
                <field name="is_late"/>
            </list>
        </field>
    </record>

<!-- Vista de búsqueda eliminada temporalmente para depuración -->

    <record id="view_sgs_service_form" model="ir.ui.view">
        <field name="name">sgs.route.service.form</field>
        <field name="model">sgs.route.service</field>
        <field name="arch" type="xml">
            <form string="Servicio / Gasto">
                <header>
                    <button name="action_approve" type="object" string="Autorizar" class="btn-primary" invisible="status == 'approved'"/>
                    <button name="action_reject" type="object" string="Rechazar" class="btn-secondary" invisible="status == 'rejected'"/>
                    <button name="action_pending" type="object" string="Marcar pendiente" invisible="status == 'pending'"/>
                    <field name="status" widget="statusbar" statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="custodian_id"/>
                            <field name="date"/>
                            <field name="submit_datetime"/>
                            <field name="is_late"/>
                            <field name="client_id"/>
                        </group>
                        <group>
                            <field name="origin"/>
                            <field name="destination"/>
                            <field name="companion"/>
                            <field name="vehicle_id"/>
                            <field name="vehicle_snapshot"/>
                            <field name="plate_snapshot"/>
                        </group>
                    </group>
                    <group string="Desglose de gastos">
                        <group>
                            <field name="amount_perdiem"/>
                            <field name="amount_fuel"/>
                            <field name="amount_lodging"/>
                            <field name="amount_misc"/>
                            <field name="misc_detail"/>
                        </group>
                        <group>
                            <field name="amount_tolls" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="evidence_image" widget="image" filename="evidence_filename"/>
                            <field name="evidence_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Casetas"><field name="toll_line_ids"><list editable="bottom"><field name="name"/><field name="amount"/><field name="image" widget="image" filename="image_filename"/><field name="image_filename" invisible="1"/></list></field></page>
                        <page string="Comentarios"><field name="comments"/><field name="validation_note"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sgs_deposit_list" model="ir.ui.view">
        <field name="name">sgs.perdiem.deposit.list</field>
        <field name="model">sgs.perdiem.deposit</field>
        <field name="arch" type="xml"><list><field name="date"/><field name="custodian_id"/><field name="month"/><field name="week"/><field name="concept"/><field name="amount" sum="Total"/></list></field>
    </record>
    <record id="view_sgs_deposit_form" model="ir.ui.view">
        <field name="name">sgs.perdiem.deposit.form</field>
        <field name="model">sgs.perdiem.deposit</field>
        <field name="arch" type="xml"><form><sheet><group><field name="custodian_id"/><field name="date"/><field name="week"/><field name="concept"/><field name="amount"/></group></sheet><chatter/></form></field>
    </record>

    <record id="view_sgs_fiscal_list" model="ir.ui.view">
        <field name="name">sgs.fiscal.receipt.list</field>
        <field name="model">sgs.fiscal.receipt</field>
        <field name="arch" type="xml"><list><field name="date"/><field name="custodian_id"/><field name="description"/><field name="provider"/><field name="provider_vat"/><field name="amount" sum="Total"/></list></field>
    </record>
    <record id="view_sgs_fiscal_form" model="ir.ui.view">
        <field name="name">sgs.fiscal.receipt.form</field>
        <field name="model">sgs.fiscal.receipt</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_process_ocr" type="object" string="Procesar OCR" class="btn-primary" invisible="ocr_status == 'processing'"/>
                    <field name="ocr_status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="ocr_status != 'processing'">
                        Procesando imagen con IA... por favor espere.
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="not ocr_error_message">
                        <field name="ocr_error_message"/>
                    </div>
                    <group>
                        <group string="Datos del Comprobante">
                            <field name="custodian_id"/>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="description"/>
                            <field name="provider"/>
                            <field name="provider_vat"/>
                        </group>
                        <group string="Imagen">
                            <field name="image" widget="image" filename="image_filename"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Resultados OCR" invisible="ocr_status == 'pending'">
                            <group>
                                <group>
                                    <field name="is_fiscal" readonly="1"/>
                                    <field name="rfc_emitter" readonly="1"/>
                                    <field name="emitter_name" readonly="1"/>
                                </group>
                                <group>
                                    <field name="ocr_date" readonly="1"/>
                                    <field name="ocr_amount" readonly="1"/>
                                </group>
                            </group>
                            <group string="JSON Crudo">
                                <field name="ocr_raw_data" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sgs_vehicle_list" model="ir.ui.view"><field name="name">sgs.vehicle.list</field><field name="model">sgs.vehicle</field><field name="arch" type="xml"><list><field name="plate"/><field name="brand"/><field name="model"/><field name="year"/><field name="color"/><field name="assigned_to"/></list></field></record>
    <record id="view_sgs_vehicle_form" model="ir.ui.view"><field name="name">sgs.vehicle.form</field><field name="model">sgs.vehicle</field><field name="arch" type="xml"><form><sheet><group><field name="brand"/><field name="model"/><field name="year"/><field name="plate"/><field name="color"/><field name="assigned_to"/></group></sheet></form></field></record>

    <record id="view_sgs_client_list" model="ir.ui.view"><field name="name">sgs.client.list</field><field name="model">sgs.client</field><field name="arch" type="xml"><list editable="bottom"><field name="name"/><field name="active"/></list></field></record>
    <record id="view_sgs_client_form" model="ir.ui.view"><field name="name">sgs.client.form</field><field name="model">sgs.client</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="active"/></group></sheet></form></field></record>
</odoo>
