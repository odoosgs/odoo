<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Formulario para Lote de Carga de Depósitos -->
        <record id="sgs_deposit_batch_form_view" model="ir.ui.view">
            <name>sgs.deposit.batch.form</name>
            <model>sgs.deposit.batch</model>
            <arch type="xml">
                <form string="Lote de Carga de Depósitos">
                    <header>
                        <button name="action_process_batch" string="Procesar Archivos" type="object" class="oe_highlight" attrs="{'invisible': [('state', 'not in', ['draft', 'error'])]}"/>
                        <button name="action_validate_batch" string="Validar y Crear Depósitos" type="object" class="oe_highlight" attrs="{'invisible': [('state', 'not in', ['processed'])]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,processing,processed,validated"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="user_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="total_files"/>
                                <field name="processed_files"/>
                                <field name="error_files"/>
                                <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Archivos de Depósito">
                                <field name="deposit_file_ids" mode="kanban,tree">
                                    <kanban>
                                        <field name="status"/>
                                        <field name="error_message"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div t-attf-class="oe_kanban_global_click">
                                                    <div class="o_kanban_image">
                                                        <img t-att-src="kanban_image(\'sgs.deposit.file\', \'file_content\', record.id.raw_value)" alt="Archivo"/>
                                                    </div>
                                                    <div class="oe_kanban_details">
                                                        <strong class="o_kanban_record_title">
                                                            <field name="name"/>
                                                        </strong>
                                                        <ul>
                                                            <li>Estado: <field name="status" widget="badge" decoration-info="status == 'pending'" decoration-warning="status == 'processing'" decoration-success="status == 'processed'" decoration-danger="status == 'error'"/></li>
                                                            <li t-if="record.extracted_amount.raw_value">Monto: <field name="extracted_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/></li>
                                                            <li t-if="record.extracted_date.raw_value">Fecha: <field name="extracted_date"/></li>
                                                            <li t-if="record.employee_id.raw_value">Custodio: <field name="employee_id"/></li>
                                                            <li t-if="record.error_message.raw_value" class="text-danger">Error: <field name="error_message"/></li>
                                                        </ul>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="status" widget="badge" decoration-info="status == 'pending'" decoration-warning="status == 'processing'" decoration-success="status == 'processed'" decoration-danger="status == 'error'"/>
                                        <field name="extracted_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        <field name="extracted_date"/>
                                        <field name="employee_id"/>
                                        <field name="error_message"/>
                                        <field name="deposit_id"/>
                                        <field name="file_content" filename="name" invisible="1"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </arch>
        </record>

        <!-- Vista de Árbol para Lote de Carga de Depósitos -->
        <record id="sgs_deposit_batch_tree_view" model="ir.ui.view">
            <name>sgs.deposit.batch.tree</name>
            <model>sgs.deposit.batch</model>
            <arch type="xml">
                <tree string="Lotes de Carga de Depósitos">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="user_id"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'processing'" decoration-success="state == 'processed'" decoration-danger="state == 'error'"/>
                    <field name="total_files"/>
                    <field name="processed_files"/>
                    <field name="error_files"/>
                    <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </tree>
            </arch>
        </record>

        <!-- Acción de Ventana para Lote de Carga de Depósitos -->
        <record id="action_sgs_deposit_batch" model="ir.actions.act_window">
            <name>Carga Masiva de Depósitos</name>
            <res_model>sgs.deposit.batch</res_model>
            <view_mode>tree,form</view_mode>
            <help type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea un nuevo lote para cargar depósitos de forma masiva.
                </p><p>
                    Arrastra y suelta tus PDFs de comprobantes de depósito aquí para que Odoo los procese automáticamente.
                </p>
            </help>
        </record>

        <!-- Menú para Carga Masiva de Depósitos -->
        <menuitem id="menu_sgs_deposit_batch" name="Carga Masiva Depósitos" parent="menu_sgs_operations" action="action_sgs_deposit_batch" sequence="40"/>

    </data>
</odoo>
