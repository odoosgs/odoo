<odoo>
    <template id="portal_ocr_home" name="Captura OCR SGS">
        <t t-call="portal.portal_layout">
            <div class="sgs-portal">
                <section class="sgs-card">
                    <h2>Subir foto para OCR</h2>
                    <form t-att-action="'/sgs/custodio/%s/ocr' % token" method="post" enctype="multipart/form-data" class="sgs-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <label>Tipo
                            <select name="document_type">
                                <option value="toll">Caseta</option>
                                <option value="lodging">Hospedaje</option>
                                <option value="food">Alimentos</option>
                                <option value="misc">Varios</option>
                                <option value="invoice">Factura</option>
                            </select>
                        </label>
                        <label>Foto
                            <input type="file" name="image" accept="image/*" required="required"/>
                        </label>
                        <button type="submit" class="sgs-btn primary">Procesar</button>
                    </form>
                </section>
            </div>
        </t>
    </template>

    <template id="portal_ocr_review" name="Revisión OCR SGS">
        <t t-call="portal.portal_layout">
            <div class="sgs-portal">
                <section class="sgs-card">
                    <h2>Revisar comprobante</h2>
                    <form t-att-action="'/sgs/custodio/%s/ocr/%s/confirm' % (token, doc.id)" method="post" class="sgs-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <label>Tipo
                            <select name="document_type">
                                <option value="toll" t-att-selected="doc.document_type == 'toll'">Caseta</option>
                                <option value="lodging" t-att-selected="doc.document_type == 'lodging'">Hospedaje</option>
                                <option value="food" t-att-selected="doc.document_type == 'food'">Alimentos</option>
                                <option value="misc" t-att-selected="doc.document_type == 'misc'">Varios</option>
                                <option value="invoice" t-att-selected="doc.document_type == 'invoice'">Factura</option>
                            </select>
                        </label>
                        <label>Fecha<input type="date" name="date" t-att-value="doc.date"/></label>
                        <label>Monto<input type="number" step="0.01" name="amount" t-att-value="doc.amount"/></label>
                        <label>Proveedor<input name="vendor" t-att-value="doc.vendor or ''"/></label>
                        <label>RFC<input name="rfc" t-att-value="doc.rfc or ''"/></label>
                        <label>Concepto<textarea name="concept"><t t-esc="doc.concept or ''"/></textarea></label>
                        <button type="submit" class="sgs-btn blue">Confirmar y guardar</button>
                    </form>
                </section>
            </div>
        </t>
    </template>
</odoo>
