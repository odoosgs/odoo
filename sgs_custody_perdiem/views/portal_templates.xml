<odoo>
    <template id="portal_custodian_home" name="Portal custodio SGS">
        <t t-call="portal.portal_layout">
            <div class="container my-4 sgs-portal">
                <div class="sgs-header">
                    <div>
                        <div class="sgs-overline">SGS · Control de Viáticos</div>
                        <h1 class="mb-1">
                            <t t-esc="custodian.name"/>
                        </h1>
                        <p class="mb-0">
                            <t t-esc="custodian.employee_number or ''"/>
                            <t t-if="custodian.position"> · <t t-esc="custodian.position"/></t>
                        </p>
                    </div>

                    <div class="sgs-balance" t-att-class="custodian.balance &lt; 0 and 'sgs-balance negative' or 'sgs-balance'">
                        <span>Saldo disponible</span>
                        <strong>
                            <t t-esc="format_amount(custodian.balance, custodian.currency_id)"/>
                        </strong>
                    </div>
                </div>

                <section class="sgs-kpis">
                    <div class="sgs-kpi">
                        <span>Fondo inicial</span>
                        <strong><t t-esc="format_amount(custodian.initial_fund, custodian.currency_id)"/></strong>
                    </div>
                    <div class="sgs-kpi">
                        <span>Depósitos</span>
                        <strong><t t-esc="format_amount(custodian.total_deposits, custodian.currency_id)"/></strong>
                    </div>
                    <div class="sgs-kpi">
                        <span>Gastos</span>
                        <strong><t t-esc="format_amount(custodian.total_expenses, custodian.currency_id)"/></strong>
                    </div>
                    <div class="sgs-kpi">
                        <span>Facturas</span>
                        <strong><t t-esc="format_amount(custodian.total_fiscal, custodian.currency_id)"/></strong>
                    </div>
                </section>

                <section class="sgs-grid">
                    <article class="sgs-card">
                        <h2>Comprobar por foto</h2>
                        <p>
                            Sube una imagen del ticket, caseta o factura y el sistema intentará leer los datos automáticamente.
                        </p>
                        <div class="d-flex flex-wrap gap-2">
                            <a t-att-href="'/sgs/custodio/%s/ocr' % token" class="sgs-btn primary text-decoration-none">
                                Abrir captura OCR
                            </a>
                        </div>
                    </article>

                    <article class="sgs-card">
                        <h2>Movimientos recientes</h2>
                        <div class="sgs-movements">
                            <t t-foreach="services" t-as="svc">
                                <div class="sgs-move">
                                    <div>
                                        <strong><t t-esc="svc.name"/></strong><br/>
                                        <span>
                                            <t t-esc="svc.date"/> ·
                                            <t t-esc="svc.origin or ''"/> →
                                            <t t-esc="svc.destination or ''"/>
                                        </span>
                                    </div>
                                    <div class="text-end">
                                        <strong><t t-esc="format_amount(svc.amount_total, svc.currency_id)"/></strong><br/>
                                        <span t-att-class="'st ' + svc.status">
                                            <t t-esc="dict(svc._fields['status'].selection).get(svc.status)"/>
                                        </span>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </article>
                </section>
            </div>
        </t>
    </template>

    <template id="portal_ocr_home" name="Captura OCR SGS">
        <t t-call="portal.portal_layout">
            <div class="container my-4 sgs-portal">
                <section class="sgs-card">
                    <h2>Subir foto para OCR</h2>
                    <p class="text-muted">
                        Toma una sola fotografía del comprobante y el sistema intentará leer monto, fecha, proveedor y RFC.
                    </p>

                    <form t-att-action="'/sgs/custodio/%s/ocr' % token" method="post" enctype="multipart/form-data" class="sgs-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <label>
                            Tipo de documento
                            <select name="document_type" class="form-select">
                                <option value="toll">Caseta</option>
                                <option value="lodging">Hospedaje</option>
                                <option value="food">Alimentos</option>
                                <option value="misc">Varios</option>
                                <option value="invoice">Factura</option>
                            </select>
                        </label>

                        <label>
                            Foto del comprobante
                            <input type="file" name="image" accept="image/*" capture="environment" class="form-control" required="required"/>
                        </label>

                        <button type="submit" class="sgs-btn primary">
                            Procesar OCR
                        </button>
                    </form>
                </section>
            </div>
        </t>
    </template>

    <template id="portal_ocr_review" name="Revisión OCR SGS">
        <t t-call="portal.portal_layout">
            <div class="container my-4 sgs-portal">
                <section class="sgs-card">
                    <h2>Revisar comprobante</h2>
                    <p class="text-muted">
                        Verifica los datos detectados y confirma el registro.
                    </p>

                    <div class="mb-3">
                        <t t-if="doc.image">
                            <img t-att-src="'data:image/png;base64,%s' % doc.image.decode('utf-8')" alt="Comprobante" class="img-fluid rounded border"/>
                        </t>
                    </div>

                    <form t-att-action="'/sgs/custodio/%s/ocr/%s/confirm' % (token, doc.id)" method="post" class="sgs-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <label>
                            Tipo de documento
                            <select name="document_type" class="form-select">
                                <option value="toll" t-att-selected="doc.document_type == 'toll'">Caseta</option>
                                <option value="lodging" t-att-selected="doc.document_type == 'lodging'">Hospedaje</option>
                                <option value="food" t-att-selected="doc.document_type == 'food'">Alimentos</option>
                                <option value="misc" t-att-selected="doc.document_type == 'misc'">Varios</option>
                                <option value="invoice" t-att-selected="doc.document_type == 'invoice'">Factura</option>
                            </select>
                        </label>

                        <label>
                            Fecha
                            <input type="date" name="date" t-att-value="doc.date or ''" class="form-control"/>
                        </label>

                        <label>
                            Monto
                            <input type="number" step="0.01" name="amount" t-att-value="doc.amount or 0.0" class="form-control"/>
                        </label>

                        <label>
                            Proveedor
                            <input name="vendor" t-att-value="doc.vendor or ''" class="form-control"/>
                        </label>

                        <label>
                            RFC
                            <input name="rfc" t-att-value="doc.rfc or ''" class="form-control"/>
                        </label>

                        <label>
                            Concepto
                            <textarea name="concept" class="form-control"><t t-esc="doc.concept or ''"/></textarea>
                        </label>

                        <button type="submit" class="sgs-btn blue">
                            Confirmar y guardar
                        </button>
                    </form>
                </section>
            </div>
        </t>
    </template>
</odoo>
