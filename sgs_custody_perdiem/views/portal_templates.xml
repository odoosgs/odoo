<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_custodian_home" name="Portal del Custodio">
        <t t-call="portal.portal_layout">
            <div id="wrap" class="container py-4">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body text-center">
                                <h2 class="mb-1"><t t-esc="custodian.name"/></h2>
                                <p class="text-muted mb-3">Portal de Gestión de Viáticos</p>
                                <div class="row text-center mt-4">
                                    <div class="col-6 border-end">
                                        <h4 class="mb-0"><t t-esc="custodian.balance" t-options="{'widget': 'monetary', 'display_currency': custodian.currency_id}"/></h4>
                                        <small class="text-muted">Saldo Disponible</small>
                                    </div>
                                    <div class="col-6">
                                        <span t-attf-class="badge rounded-pill p-2 px-3 bg-#{'success' if custodian.compliance_state == 'green' else 'warning' if custodian.compliance_state == 'yellow' else 'danger' if custodian.compliance_state == 'red' else 'info'}">
                                            <t t-esc="dict(custodian._fields['compliance_state'].selection).get(custodian.compliance_state)"/>
                                        </span>
                                          
<small class="text-muted">Estado de Cumplimiento</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Formulario de Registro de Servicio -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fa fa-road me-2"/>Registrar Nuevo Servicio / Gasto</h5>
                    </div>
                    <div class="card-body">
                        <form t-attf-action="/sgs/custodio/#{token}/servicio" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Cliente</label>
                                    <select name="client_id" class="form-select" required="1">
                                        <option value="">Seleccione un cliente...</option>
                                        <t t-foreach="clients" t-as="client">
                                            <option t-att-value="client.id"><t t-esc="client.name"/></option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Vehículo</label>
                                    <select name="vehicle_id" class="form-select" required="1">
                                        <option value="">Seleccione vehículo...</option>
                                        <t t-foreach="vehicles" t-as="vehicle">
                                            <option t-att-value="vehicle.id"><t t-esc="vehicle.name"/> [<t t-esc="vehicle.license_plate"/>]</option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                            <!-- Resto del formulario... -->
                            <button type="submit" class="btn btn-primary btn-lg w-100 mt-4">Enviar Reporte</button>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
