<odoo>
    <!-- Botón en el menú del portal de Odoo -->
    <template id="portal_my_home_viaticos" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Mis Viáticos SGS</t>
                <t t-set="url" t-value="'/my/viaticos'"/>
                <t t-set="placeholder">Consultar saldo y reportar</t>
            </t>
        </xpath>
    </template>

    <!-- Vista Principal del Custodio (Estilo Oscuro) -->
    <template id="sgs_portal_layout">
        <t t-call="portal.portal_layout">
            <style>
                :root {
                    --bg:#060C18; --surf:#0C1526; --acc:#C8A84B; --text:#EEF2F8; --pos:#27AE60; --red:#C0392B;
                }
                .sgs-container { background: var(--bg); color: var(--text); min-height: 100vh; padding: 20px; font-family: 'sans-serif'; }
                .cv-bal { background: linear-gradient(135deg, #0A1628, #12203A); border: 1px solid #2A4F80; border-radius: 12px; padding: 30px; text-align: center; position: relative; }
                .cv-bal::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:var(--acc); }
                .bla { font-size: 2.5rem; font-weight: bold; color: white; }
                .cv-ab { width: 100%; background: var(--acc); color: black; font-weight: bold; padding: 15px; border-radius: 8px; border:none; margin: 20px 0; }
                .mi-card { background: #0C1526; border-left: 4px solid var(--acc); margin-bottom: 10px; padding: 15px; border-radius: 5px; }
            </style>

            <div class="sgs-container">
                <div class="d-flex align-items-center mb-4">
                    <div class="flex-grow-1">
                        <h3 class="mb-0">SGS Custodia</h3>
                        <small class="text-muted"><t t-esc="employee.name"/></small>
                    </div>
                </div>

                <div class="cv-bal">
                    <div style="font-size: 0.8rem; letter-spacing: 2px;">SALDO DISPONIBLE</div>
                    <div class="bla">$ <t t-esc="'{0:,.2f}'.format(saldo_actual)"/></div>
                </div>

                <button class="cv-ab" data-bs-toggle="modal" data-bs-target="#modalGasto">
                    + REGISTRAR GASTO
                </button>

                <h5 class="mt-4 mb-3">Últimos Movimientos</h5>
                <div class="ml">
                    <t t-foreach="gastos" t-as="g">
                        <div class="mi-card">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold"><t t-esc="g.name"/></div>
                                    <small class="text-muted"><t t-esc="g.date"/></small>
                                </div>
                                <div class="text-danger fw-bold">-$ <t t-esc="g.amount"/></div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Modal Reporte -->
            <div class="modal fade" id="modalGasto" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-white">
                        <form action="/my/viaticos/save" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="modal-body">
                                <label>Concepto</label>
                                <input type="text" name="name" class="form-control mb-3" required="1" placeholder="Ej. Comida Chilpancingo"/>
                                <label>Monto</label>
                                <input type="number" name="amount" step="0.01" class="form-control mb-3" required="1"/>
                                <label>Categoría</label>
                                <select name="category" class="form-control mb-3">
                                    <option value="alimentacion">Alimentación</option>
                                    <option value="combustible">Combustible</option>
                                    <option value="peaje">Peaje</option>
                                    <option value="otros">Otros</option>
                                </select>
                                <label>Foto Comprobante</label>
                                <input type="file" name="receipt_image" class="form-control" accept="image/*" capture="camera"/>
                            </div>
                            <div class="modal-footer border-0">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                <button type="submit" class="btn btn-warning">Enviar Reporte</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
