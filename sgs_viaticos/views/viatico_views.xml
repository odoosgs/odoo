<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA LISTA ENTREGAS -->
    <record id="view_sgs_viatico_entrega_list" model="ir.ui.view">
        <field name="name">sgs.viatico.entrega.list</field>
        <field name="model">sgs.viatico.entrega</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="amount" sum="Total"/>
                <field name="date"/>
                <field name="state" widget="badge" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- VISTA FORMULARIO ENTREGAS (ESTO CORRIGE TU IMAGEN) -->
    <record id="view_sgs_viatico_entrega_form" model="ir.ui.view">
        <field name="name">sgs.viatico.entrega.form</field>
        <field name="model">sgs.viatico.entrega</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Referencia"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ACCIÓN QUE UNE TODO -->
    <record id="action_sgs_viatico_entrega" model="ir.actions.act_window">
        <field name="name">Entregas de Efectivo</field>
        <field name="res_model">sgs.viatico.entrega</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_sgs_viatico_entrega_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra la primera entrega de efectivo</p>
        </field>
    </record>

    <!-- REPETIR LÓGICA PARA GASTOS -->
    <record id="view_sgs_viatico_gasto_list" model="ir.ui.view">
        <field name="name">sgs.viatico.gasto.list</field>
        <field name="model">sgs.viatico.gasto</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'reported'">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_sgs_viatico_gasto_form" model="ir.ui.view">
        <field name="name">sgs.viatico.gasto.form</field>
        <field name="model">sgs.viatico.gasto</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Aprobar" type="object" class="oe_highlight" invisible="state != 'reported'"/>
                    <button name="action_refuse" string="Rechazar" type="object" invisible="state != 'reported'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="name"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <group string="Evidencia">
                        <field name="receipt_image" widget="image" class="oe_avatar"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_sgs_viatico_gasto" model="ir.actions.act_window">
        <field name="name">Gastos Reportados</field>
        <field name="res_model">sgs.viatico.gasto</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_sgs_viatico_gasto_list"/>
    </record>
</odoo>
