<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Definición de la Categoría -->
        <record id="module_category_sgs_viaticos" model="ir.module.category">
            <field name="name">SGS Viáticos</field>
            <field name="description">Gestión de viáticos para custodios</field>
            <field name="sequence">10</field>
        </record>

        <!-- Grupo de Administrador -->
        <record id="group_sgs_viaticos_user" model="res.groups">
            <field name="name">Administrador de Viáticos</field>
            <field name="category_id" ref="sgs_viaticos.module_category_sgs_viaticos"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
