<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Definimos la categoría de forma independiente -->
        <record id="module_category_sgs_viaticos" model="ir.module.category">
            <field name="name">SGS Viáticos</field>
            <field name="description">Gestión de viáticos para custodios</field>
            <field name="sequence">10</field>
        </record>

        <!-- Definimos el grupo SIN usar el campo category_id para evitar el conflicto -->
        <record id="group_sgs_viaticos_user" model="res.groups">
            <field name="name">SGS / Administrador de Viáticos</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <!-- Asociamos la categoría por fuera si es necesario, o lo dejamos así para que instale -->
        </record>
    </data>
</odoo>
