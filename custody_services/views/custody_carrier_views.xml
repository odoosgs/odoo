<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción de Ventana para el Catálogo de Carriers -->
    <record id="action_custody_carrier" model="ir.actions.act_window">
        <field name="name">Carriers (Transportistas)</field>
        <field name="res_model">x_custody_carrier</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea el primer Transportista (Carrier) para gestionar los servicios de custodia.
            </p>
        </field>
    </record>

    <!-- Vista de Lista (List View) de Carriers -->
    <record id="view_custody_carrier_list" model="ir.ui.view">
        <field name="name">x_custody_carrier_list</field>
        <field name="model">x_custody_carrier</field>
        <field name="arch" type="xml">
            <list string="Transportistas" sample="1">
                <field name="name" string="Carrier"/>
                <field name="carrier_type"/>
                <field name="vat" string="RFC/ID Fiscal"/>
                <field name="contact_name"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vista de Formulario (Form View) de Carriers -->
    <record id="view_custody_carrier_form" model="ir.ui.view">
        <field name="name">x_custody_carrier_form</field>
        <field name="model">x_custody_carrier</field>
        <field name="arch" type="xml">
            <form string="Detalle del Carrier">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Botones futuros: e.g., servicios, vehículos, etc. -->
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    
                    <group>
                        <group string="Información General">
                            <field name="carrier_type"/>
                            <field name="vat" string="RFC/ID Fiscal"/>
                            <field name="is_active" widget="toggle_button"/>
                        </group>
                        <group string="Contacto Principal">
                            <field name="contact_name"/>
                            <field name="contact_phone"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page name="address" string="Dirección">
                            <group>
                                <field name="street"/>
                                <field name="street2"/>
                                <field name="zip"/>
                                <field name="city"/>
                                <field name="country_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="state_id" options="{'no_open': True, 'no_create': True}" 
                                       context="{'country_id': country_id}"
                                       domain="[('country_id', '=', country_id)]"/>
                            </group>
                        </page>
                        <page name="compliance" string="Cumplimiento y Seguridad">
                            <group string="Seguro y Documentación">
                                <field name="insurance_policy"/>
                                <field name="insurance_expiry_date"/>
                                <label for="insurance_expiry_date" string="Estatus de Vigencia"/>
                                <div>
                                    <span class="text-muted">Añadir aquí lógica de semáforo (Verde/Rojo)</span>
                                </div>
                            </group>
                        </page>
                        <page name="internal_notes" string="Notas Internas">
                            <field name="message_ids" widget="mail_thread"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    
<!-- Vista de Búsqueda (Search View) de Carriers -->
<record id="view_custody_carrier_search" model="ir.ui.view">
    <field name="name">x_custody_carrier_search</field>
    <field name="model">x_custody_carrier</field>
    <field name="arch" type="xml">
        <search string="Buscar Transportista">
            <field name="name" filter_domain="['|', ('name', 'ilike', self), ('vat', 'ilike', self)]"/>
            <field name="vat" string="RFC"/>
            <filter string="Activos" name="filter_active" domain="[('is_active', '=', True)]"/>
            <separator/>
            <field name="city"/>
            <group expand="0" string="Agrupar Por">
                <filter string="Tipo de Carrier" name="groupby_carrier_type" context="{'group_by':'carrier_type'}"/>
            </group>
        </search>
    </field>
</record>

</odoo>


