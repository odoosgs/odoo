<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_service_list" name="Mis Servicios">
        <t t-call="portal.portal_layout">
            <div class="container my-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="m-0 text-primary">Mis Servicios de Custodia</h2>
                    <a href="/solicitar-servicio" class="btn btn-primary shadow-sm">
                        <i class="fa fa-plus me-1"/> Solicitar Servicio
                    </a>
                </div>
                <div class="table-responsive bg-white shadow-sm rounded">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Folio</th>
                                <th>Ruta</th>
                                <th>Inicio</th>
                                <th>Estado</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="services" t-as="s">
                                <tr class="align-middle">
                                    <td class="fw-bold"><t t-esc="s.sequence"/></td>
                                    <td><t t-esc="s.ruta_id.name"/></td>
                                    <td><t t-esc="s.start_datetime" t-options='{"widget": "datetime"}'/></td>
                                    <td><span t-field="s.state" class="badge rounded-pill bg-info"/></td>
                                    <td class="text-end">
                                        <a t-att-href="'/mis-servicios/%s?access_token=%s' % (s.id, s.access_token)" class="btn btn-sm btn-outline-secondary">Ver</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_service_form" name="Solicitud de Servicio">
        <t t-call="portal.portal_layout">
            <div id="wrap" class="container my-4 bg-white p-4 shadow-sm rounded">
                <h2 class="mb-4 text-primary">Nueva Solicitud</h2>
                <form action="/solicitar-servicio/submit" method="post" class="row g-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Persona Solicitante</label>
                        <select name="contact_id" class="form-select" required="1">
                            <t t-foreach="contacts" t-as="c"><option t-att-value="c.id"><t t-esc="c.display_name"/></option></t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Carrier</label>
                        <select name="carrier_id" class="form-select" required="1">
                            <t t-foreach="carriers" t-as="car"><option t-att-value="car.id"><t t-esc="car.name"/></option></t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ruta</label>
                        <select name="ruta_id" class="form-select" required="1">
                            <t t-foreach="rutas" t-as="r"><option t-att-value="r.id"><t t-esc="r.name"/></option></t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Inicio Estimado</label>
                        <input type="datetime-local" name="start_datetime" class="form-control" required="1"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nivel de Seguridad</label>
                        <select name="nivel_seguridad" class="form-select" required="1">
                            <option value="">-- Seleccione --</option>
                            <option value="1">Nivel 1</option>
                            <option value="2">Nivel 2</option>
                            <option value="3">Nivel 3</option>
                            <option value="4">Nivel 4</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Load ID</label>
                        <input type="text" name="load_id" class="form-control" required="1"/>
                    </div>
                    <div class="col-12 mt-4 text-end">
                        <button type="submit" class="btn btn-success btn-lg shadow-sm">Registrar Solicitud</button>
                    </div>
                </form>
            </div>
        </t>
    </template>

    <template id="portal_service_detail" name="Detalle del Servicio">
        <t t-call="portal.portal_layout">
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

            <div class="container my-4 bg-white pb-5 shadow-sm rounded">
                <div class="d-flex justify-content-between align-items-center pt-3 px-3">
                    <h2 class="mb-0 text-primary">Servicio <t t-esc="service.sequence"/></h2>
                    <span t-field="service.state" class="badge rounded-pill bg-info p-2 px-3"/>
                </div>
                <hr class="mx-3"/>

                <div class="row mt-4 px-3">
                    <div class="col-md-6">
                        <h5 class="text-muted border-bottom pb-2">Información de Ruta</h5>
                        <p><b>Cliente:</b> <t t-esc="cliente.display_name"/></p>
                        <p><b>Ruta:</b> <t t-esc="service.ruta_id.name"/></p>
                        <p><b>Inicio:</b> <t t-esc="service.start_datetime"/></p>
                        <p><b>Nivel:</b> Nivel <t t-esc="service.nivel_seguridad"/></p>
                    </div>
                    <div class="col-md-6 border-start">
                        <h5 class="text-muted border-bottom pb-2">Logística</h5>
                        <ul class="list-unstyled">
                            <li><b>Unidad:</b> <span t-field="service.tipo_unidad"/></li>
                            <li><b>Placas:</b> <span t-field="service.placas"/></li>
                            <li><b>Operador:</b> <span t-field="service.operador1_nombre"/></li>
                        </ul>
                    </div>
                </div>

                <div class="row mt-5 px-3">
                    <div class="col-lg-6 mb-4">
                        <h4 class="text-secondary">Ruta Planeada</h4>
                        <div id="route_map" t-att-data-ruta-id="service.ruta_id.id" style="height:400px;" class="border rounded shadow-sm"></div>
                        <div id="route_info" class="mt-2 p-2 bg-light border rounded text-center small" style="display:none;"></div>
                    </div>
                    <div class="col-lg-6 mb-4">
                        <h4 class="text-secondary">Monitoreo en Vivo</h4>
                        <div id="live_map" style="height:400px;" class="border rounded shadow-sm"></div>
                    </div>
                </div>

                <div id="service_communication" class="mt-4 pt-4 border-top px-3">
                    <t t-call="portal.message_thread">
                        <t t-set="object" t-value="service"/>
                        <t t-set="token" t-value="service.access_token"/>
                    </t>
                </div>
            </div>

            <script type="text/javascript">
            <![CDATA[
            document.addEventListener("DOMContentLoaded", function () {
                var sId = "]]><t t-out='service.id'/><![CDATA[";
                var tok = "]]><t t-out='service.access_token'/><![CDATA[";
                var liveMap = L.map('live_map').setView([19.43, -99.13], 6);
                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(liveMap);
                var marker = L.marker([19.43, -99.13]).addTo(liveMap);

                function up() {
                    fetch("/mis-servicios/" + sId + "/tracking", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ params: { access_token: tok } })
                    }).then(res => res.json()).then(d => {
                        var r = d.result || d;
                        if (r.lat && r.lng) {
                            marker.setLatLng([r.lat, r.lng]);
                            liveMap.panTo([r.lat, r.lng]);
                        }
                    });
                }
                up(); setInterval(up, 15000);
            });
            ]]>
            </script>
        </t>
    </template>
</odoo>
