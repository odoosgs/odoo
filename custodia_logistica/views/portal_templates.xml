<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_service_list" name="Mis Servicios">
        <t t-call="portal.portal_layout">
            <div class="container my-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2>Mis Servicios de Custodia</h2>
                    <a href="/solicitar-servicio" class="btn btn-primary">
                        Solicitar Servicio
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Consecutivo</th>
                                <th>Ruta</th>
                                <th>Inicio</th>
                                <th>Nivel</th>
                                <th>Estado</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="services">
                                <t t-foreach="services" t-as="s">
                                    <tr>
                                        <td><t t-esc="s.sequence"/></td>
                                        <td><t t-esc="s.ruta_id.name"/></td>
                                        <td><t t-esc="s.start_datetime"/></td>
                                        <td><t t-esc="s.nivel_seguridad"/></td>
                                        <td>
                                            <span t-field="s.state"
                                                  class="badge rounded-pill bg-info"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-att-href="'/mis-servicios/%s?access_token=%s' % (s.id, s.access_token)"
                                               class="btn btn-sm btn-secondary">
                                                Ver
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        No existen servicios registrados.
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

            </div>
        </t>
    </template>


    <template id="portal_service_detail" name="Detalle del Servicio">
        <t t-call="portal.portal_layout">

            <t t-call-assets="web.assets_frontend">
                <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                <link rel="stylesheet"
                      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
            </t>

            <div class="container my-4 bg-white pb-5">

                <div class="d-flex justify-content-between align-items-center pt-3">
                    <h2>
                        Servicio <t t-esc="service.sequence"/>
                    </h2>
                    <span t-field="service.state"
                          class="badge rounded-pill bg-info"
                          style="font-size: 1rem;"/>
                </div>

                <hr/>

                <div class="row mt-4">
                    <div class="col-md-6">
                        <p><b>Cliente:</b> <t t-esc="cliente.display_name"/></p>
                        <p>
                            <b>Ruta:</b>
                            <t t-esc="service.ruta_id.name"/>
                            (<t t-esc="service.ruta_tipo"/>)
                        </p>
                        <p><b>Inicio:</b> <t t-esc="service.start_datetime"/></p>
                        <p><b>Nivel:</b> <t t-esc="service.nivel_seguridad"/></p>
                        <p><b>Load ID:</b> <t t-esc="service.load_id"/></p>
                    </div>
                </div>

                <div class="mt-5">
                    <h3>Monitoreo en Vivo</h3>
                    <div id="live-map" style="height:450px;"></div>
                </div>

            </div>

            <script type="text/javascript">
            <![CDATA[
            document.addEventListener("DOMContentLoaded", function () {

                var serviceId = "]]><t t-out='service.id'/><![CDATA[";
                var token = "]]><t t-out='token'/><![CDATA[";

                var map = L.map('live-map').setView([19.0, -99.0], 6);

                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                    attribution: "OpenStreetMap"
                }).addTo(map);

                var marker = L.marker([19.0, -99.0]).addTo(map);

                function updateLocation() {

                    fetch("/mis-servicios/" + serviceId + "/tracking", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            access_token: token
                        })
                    })
                    .then(function(response){
                        return response.json();
                    })
                    .then(function(data){

                        if (data.result && data.result.lat && data.result.lng) {

                            var newLatLng = [
                                data.result.lat,
                                data.result.lng
                            ];

                            marker.setLatLng(newLatLng);
                            map.panTo(newLatLng);
                        }

                    })
                    .catch(function(error){
                        console.log("Tracking error:", error);
                    });
                }

                updateLocation();
                setInterval(updateLocation, 15000);

            });
            ]]>
            </script>

        </t>
    </template>


    <template id="portal_my_home_custodia"
              inherit_id="portal.portal_my_home"
              name="Custodia Portal">

        <xpath expr="//div[contains(@class,'o_portal_docs')]"
               position="inside">

            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Servicios de Custodia</t>
                <t t-set="url" t-value="'/mis-servicios'"/>
                <t t-set="placeholder_count" t-value="'services_count'"/>
            </t>

        </xpath>
    </template>

</odoo>
