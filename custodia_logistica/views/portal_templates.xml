<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_service_list" name="Mis Servicios">
        <t t-call="portal.portal_layout">
            <div class="container my-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2>Mis Servicios de Custodia</h2>
                    <a href="/solicitar-servicio" class="btn btn-primary">Solicitar Servicio</a>
                </div>
                <table class="table table-striped bg-white shadow-sm rounded">
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Ruta</th>
                            <th>Estado</th>
                            <th class="text-end">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="services" t-as="s">
                            <tr>
                                <td><t t-esc="s.sequence"/></td>
                                <td><t t-esc="s.ruta_id.name"/></td>
                                <td><span t-field="s.state" class="badge rounded-pill bg-info"/></td>
                                <td class="text-end">
                                    <a t-att-href="'/mis-servicios/%s?access_token=%s' % (s.id, s.access_token)" class="btn btn-sm btn-secondary">Ver</a>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="portal_service_form" name="Nueva Solicitud">
        <t t-call="portal.portal_layout">
            <div id="wrap" class="container my-4 bg-white p-4 shadow-sm rounded">
                <h2 class="mb-4 text-primary">Nueva Solicitud de Custodia</h2>
                <form action="/solicitar-servicio/submit" method="post" class="row g-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Persona Solicitante</label>
                        <select name="contact_id" class="form-select" required="1">
                            <t t-foreach="contacts" t-as="c"><option t-att-value="c.id"><t t-esc="c.display_name"/></option></t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Carrier</label>
                        <select name="carrier_id" class="form-select" required="1">
                            <t t-foreach="carriers" t-as="car"><option t-att-value="car.id"><t t-esc="car.name"/></option></t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ruta</label>
                        <select name="ruta_id" class="form-select" required="1">
                            <t t-foreach="rutas" t-as="r"><option t-att-value="r.id"><t t-esc="r.name"/></option></t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nivel de Seguridad</label>
                        <select name="nivel_seguridad" class="form-select" required="1">
                            <option value="1">Nivel 1</option><option value="2">Nivel 2</option>
                            <option value="3">Nivel 3</option><option value="4">Nivel 4</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Inicio Estimado</label>
                        <input type="datetime-local" name="start_datetime" class="form-control" required="1"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Load ID</label>
                        <input type="text" name="load_id" class="form-control" required="1"/>
                    </div>
                    <div class="col-12 mt-4 text-end">
                        <button type="submit" class="btn btn-success btn-lg px-5">Registrar</button>
                    </div>
                </form>
            </div>
        </t>
    </template>

    <template id="portal_service_detail" name="Detalle del Servicio">
        <t t-call="portal.portal_layout">
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

            <div class="container my-4 bg-white pb-5 shadow-sm rounded">
                <div class="d-flex justify-content-between align-items-center pt-3 px-3">
                    <h2>Servicio <t t-esc="service.sequence"/></h2>
                    <div class="d-flex gap-2">
                        <t t-if="service.state == 'asignado'">
                            <button class="btn btn-primary btn-custodio-action" t-att-data-service-id="service.id" data-action="iniciar" id="btn-iniciar-servicio">Iniciar Servicio</button>
                        </t>
                        <t t-if="service.state == 'iniciado'">
                            <button class="btn btn-warning btn-custodio-action" t-att-data-service-id="service.id" data-action="en_ruta" id="btn-en-ruta">En Ruta</button>
                        </t>
                        <t t-if="service.state == 'en_ruta'">
                            <button class="btn btn-success btn-custodio-action" t-att-data-service-id="service.id" data-action="llegada" id="btn-llegada">Registrar Llegada</button>
                        </t>
                        <span t-field="service.state" class="badge rounded-pill bg-info p-2 px-3"/>
                    </div>
                </div>
                <hr class="mx-3"/>

                <div class="row mt-4 px-3">
                    <div class="col-md-6">
                        <p><b>Cliente:</b> <t t-esc="cliente.display_name"/></p>
                        <p><b>Ruta:</b> <t t-esc="service.ruta_id.name"/></p>
                        <p><b>Inicio:</b> <t t-esc="service.start_datetime"/></p>
                    </div>
                    <div class="col-md-6 border-start">
                        <ul class="list-unstyled">
                            <li><b>Unidad:</b> <span t-field="service.tipo_unidad"/></li>
                            <li><b>Placas:</b> <span t-field="service.placas"/></li>
                            <li><b>Operador:</b> <span t-field="service.operador1_nombre"/></li>
                        </ul>
                    </div>
                </div>

                <div class="row mt-5 px-3">
                    <div class="col-lg-6 mb-4">
                        <h4 class="text-secondary">Ruta Planeada</h4>
                        <div id="route_map" t-att-data-ruta-id="service.ruta_id.id" style="height:400px;" class="border rounded shadow-sm"></div>
                        <div id="route_info" class="mt-2 p-2 bg-light border rounded text-center small" style="display:none;"></div>
                    </div>
                    <div class="col-lg-6 mb-4">
                        <h4 class="text-secondary">Monitoreo en Vivo</h4>
                        <div id="live_map" t-att-data-service-id="service.id" t-att-data-token="service.access_token" style="height:400px;" class="border rounded shadow-sm"></div>
                    </div>
                </div>

                <div id="service_communication" class="mt-4 pt-4 border-top px-3">
                    <t t-call="portal.message_thread">
                        <t t-set="object" t-value="service"/>
                        <t t-set="token" t-value="service.access_token"/>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_my_home_custodia" inherit_id="portal.portal_my_home" name="Custodia Portal" priority="40">
        <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Servicios de Custodia</t>
                <t t-set="url" t-value="'/mis-servicios'"/>
                <t t-set="placeholder_count" t-value="'services_count'"/>
            </t>
        </xpath>
    </template>
</odoo>
