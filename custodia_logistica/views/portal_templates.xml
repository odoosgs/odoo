<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- LISTADO DE SERVICIOS -->
    <!-- ========================================================= -->
    <template id="portal_service_list" name="Mis Servicios">
        <t t-call="portal.portal_layout">
            <div class="container my-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2>Mis Servicios de Custodia</h2>
                    <a t-att-href="'/solicitar-servicio'" class="btn btn-primary">
                        Solicitar Servicio
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Folio</th>
                                <th>Ruta</th>
                                <th>Inicio</th>
                                <th>Nivel</th>
                                <th>Estado</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="services">
                                <t t-foreach="services" t-as="s">
                                    <tr>
                                        <td><t t-esc="s.sequence"/></td>
                                        <td><t t-esc="s.ruta_id.name"/></td>
                                        <td><t t-esc="s.start_datetime"/></td>
                                        <td><t t-esc="s.nivel_seguridad"/></td>
                                        <td>
                                            <span t-field="s.state"
                                                  class="badge rounded-pill bg-info"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-att-href="'/mis-servicios/%s?access_token=%s' % (s.id, s.access_token)"
                                               class="btn btn-sm btn-secondary">
                                                Ver
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        No existen servicios registrados.
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

            </div>
        </t>
    </template>


    <!-- ========================================================= -->
    <!-- DETALLE DEL SERVICIO -->
    <!-- ========================================================= -->
    <template id="portal_service_detail" name="Detalle del Servicio">
        <t t-call="portal.portal_layout">

            <!-- Leaflet -->
            <link rel="stylesheet"
                  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

            <div class="container my-4 bg-white pb-5">

                <div class="d-flex justify-content-between align-items-center pt-3">
                    <h2>Servicio <t t-esc="service.sequence"/></h2>
                    <span t-field="service.state"
                          class="badge rounded-pill bg-info"
                          style="font-size: 1rem;"/>
                </div>

                <hr/>

                <div class="row mt-4">
                    <div class="col-md-6">
                        <p><b>Cliente:</b> <t t-esc="cliente.display_name"/></p>
                        <p><b>Ruta:</b> <t t-esc="service.ruta_id.name"/></p>
                        <p><b>Inicio:</b> <t t-esc="service.start_datetime"/></p>
                        <p><b>Nivel:</b> <t t-esc="service.nivel_seguridad"/></p>
                        <p><b>Load ID:</b> <t t-esc="service.load_id"/></p>
                    </div>

                    <div class="col-md-6 border-start">
                        <h4 class="text-muted">Datos de Logística</h4>
                        <ul class="list-unstyled">
                            <li><b>Unidad:</b> <span t-field="service.tipo_unidad"/></li>
                            <li><b>Placas:</b> <span t-field="service.placas"/></li>
                            <li><b>Transporte:</b> <span t-field="service.transporte"/></li>
                            <li><b>Operador:</b> <span t-field="service.operador1_nombre"/></li>
                            <li><b>Monitoreo:</b> <span t-field="service.tel_monitoreo_1"/></li>
                        </ul>
                    </div>
                </div>

                <!-- ===================== -->
                <!-- RUTA PLANEADA -->
                <!-- ===================== -->
                <div class="mt-5">
                    <h3>Ruta Planeada</h3>
                    <div id="route-map"
                         t-att-data-ruta-id="service.ruta_id.id"
                         style="height:450px;"
                         class="border shadow-sm">
                    </div>
                </div>

                <div id="route-summary"
                     class="mt-3 p-3 bg-light border rounded text-center"
                     style="display:none;">
                    <strong>Distancia estimada:</strong>
                    <span id="route-distance"></span>
                    <span class="mx-3">|</span>
                    <strong>Tiempo estimado:</strong>
                    <span id="route-duration"></span>
                </div>

                <!-- ===================== -->
                <!-- MONITOREO EN VIVO -->
                <!-- ===================== -->
                <div class="mt-5">
                    <h3>Monitoreo en Vivo</h3>
                    <div id="live-map"
                         t-att-data-service-id="service.id"
                         t-att-data-token="service.access_token"
                         style="height:450px;"
                         class="border shadow-sm">
                    </div>
                </div>

                <!-- ===================== -->
                <!-- CHATTER -->
                <!-- ===================== -->
                <div id="service_communication" class="mt-5 pt-4 border-top">
                    <h3 class="mb-4">Seguimiento e Incidencias</h3>
                    <t t-call="portal.message_thread">
                        <t t-set="object" t-value="service"/>
                        <t t-set="token" t-value="service.access_token"/>
                    </t>
                </div>

            </div>

            <!-- JS externo -->
            <script type="text/javascript"
                    src="/custodia_logistica/static/src/js/route_map.js"></script>

        </t>
    </template>


    <!-- ========================================================= -->
    <!-- PORTAL HOME ENTRY -->
    <!-- ========================================================= -->
    <template id="portal_my_home_custodia"
              inherit_id="portal.portal_my_home"
              name="Custodia Portal">

        <xpath expr="//div[contains(@class,'o_portal_docs')]"
               position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Servicios de Custodia</t>
                <t t-set="url" t-value="'/mis-servicios'"/>
                <t t-set="placeholder_count" t-value="'services_count'"/>
            </t>
        </xpath>

    </template>

</odoo>
