<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_service_list" name="Listado de Servicios de Custodia">
        <t t-call="portal.portal_layout">
            <div class="container my-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="m-0">Mis Servicios de Custodia</h2>
                    <a href="/solicitar-servicio" class="btn btn-primary shadow-sm">
                        <i class="fa fa-plus-circle me-1"/> Solicitar Servicio
                    </a>
                </div>

                <div class="table-responsive bg-white shadow-sm rounded">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Folio</th>
                                <th>Ruta</th>
                                <th>Inicio</th>
                                <th>Nivel</th>
                                <th>Estado</th>
                                <th class="text-end">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="services">
                                <t t-foreach="services" t-as="s">
                                    <tr class="align-middle">
                                        <td class="fw-bold"><t t-esc="s.sequence"/></td>
                                        <td><t t-esc="s.ruta_id.name"/></td>
                                        <td><t t-esc="s.start_datetime" t-options='{"widget": "datetime"}'/></td>
                                        <td><span class="badge border text-dark">Nivel <t t-esc="s.nivel_seguridad"/></span></td>
                                        <td>
                                            <span t-field="s.state" class="badge rounded-pill bg-info text-white"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-att-href="'/mis-servicios/%s?access_token=%s' % (s.id, s.access_token)" 
                                               class="btn btn-sm btn-outline-secondary">
                                                Ver Detalle
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-5">
                                        No existen servicios registrados.
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_service_form" name="Nueva Solicitud de Custodia">
        <t t-call="portal.portal_layout">
            <div id="wrap" class="container my-4 bg-white p-4 shadow-sm rounded">
                <h2 class="mb-4 text-primary">Nueva Solicitud de Custodia</h2>
                <t t-if="error">
                    <div class="alert alert-danger shadow-sm" role="alert">
                        <t t-esc="error"/>
                    </div>
                </t>
                <form action="/solicitar-servicio/submit" method="post" class="row g-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Persona Solicitante</label>
                        <select name="contact_id" class="form-select" required="1">
                            <t t-foreach="contacts" t-as="c">
                                <option t-att-value="c.id"><t t-esc="c.display_name"/></option>
                            </t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Carrier</label>
                        <select name="carrier_id" class="form-select" required="1">
                            <t t-foreach="carriers" t-as="car">
                                <option t-att-value="car.id"><t t-esc="car.name"/></option>
                            </t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ruta</label>
                        <select name="ruta_id" class="form-select" required="1">
                            <t t-foreach="rutas" t-as="r">
                                <option t-att-value="r.id"><t t-esc="r.name"/></option>
                            </t>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Inicio Estimado</label>
                        <input type="datetime-local" name="start_datetime" class="form-control" required="1"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Load ID</label>
                        <input type="text" name="load_id" class="form-control" placeholder="Ej. NKS221255" required="1"/>
                    </div>
                    <div class="col-12 mt-4 text-end border-top pt-3">
                        <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm">Enviar Solicitud</button>
                    </div>
                </form>
            </div>
        </t>
    </template>

    <template id="portal_service_detail" name="Detalle del Servicio de Custodia">
        <t t-call="portal.portal_layout">
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

            <div class="container my-4 bg-white pb-5 shadow-sm rounded">
                <div class="d-flex justify-content-between align-items-center pt-3 px-3">
                    <h2 class="mb-0 text-primary">Servicio <t t-esc="service.sequence"/></h2>
                    <span t-field="service.state" class="badge rounded-pill bg-info p-2 px-3" style="font-size: 0.9rem;"/>
                </div>
                <hr class="mx-3"/>

                <div class="row mt-4 px-3">
                    <div class="col-md-6">
                        <h5 class="text-muted border-bottom pb-2">Información de Ruta</h5>
                        <p><b>Ruta:</b> <t t-esc="service.ruta_id.name"/></p>
                        <p><b>Inicio:</b> <t t-esc="service.start_datetime"/></p>
                        <p><b>Load ID:</b> <t t-esc="service.load_id"/></p>
                    </div>
                    <div class="col-md-6 border-start">
                        <h5 class="text-muted border-bottom pb-2">Unidad y Operador</h5>
                        <ul class="list-unstyled">
                            <li><b>Unidad:</b> <span t-field="service.tipo_unidad"/></li>
                            <li><b>Placas:</b> <span t-field="service.placas"/></li>
                            <li><b>Operador:</b> <span t-field="service.operador1_nombre"/></li>
                        </ul>
                    </div>
                </div>

                <div class="mt-5 px-3">
                    <h4 class="text-secondary"><i class="fa fa-map-o me-2"/>Ruta Planeada (Estimación Carretera)</h4>
                    <div id="route-map" t-att-data-ruta-id="service.ruta_id.id" style="height:400px;" class="border rounded shadow-sm"></div>
                    <div id="route-summary" class="mt-2 p-2 bg-light border rounded text-center" style="display:none;">
                        <b>Distancia Estimada:</b> <span id="route-distance" class="me-3 text-primary fw-bold"/>
                        <b>Tiempo Estimado:</b> <span id="route-duration" class="text-primary fw-bold"/>
                    </div>
                </div>

                <div class="mt-5 px-3">
                    <h4 class="text-secondary"><i class="fa fa-crosshairs me-2"/>Ubicación Actual de la Unidad</h4>
                    <div id="live-map" style="height:400px;" class="border rounded shadow-sm"></div>
                </div>

                <div id="service_communication" class="mt-5 pt-4 border-top px-3">
                    <h4 class="mb-4 text-muted"><i class="fa fa-comments-o me-2"/>Bitácora y Eventualidades</h4>
                    <t t-call="portal.message_thread">
                        <t t-set="object" t-value="service"/>
                        <t t-set="token" t-value="service.access_token"/>
                    </t>
                </div>
            </div>

            <script type="text/javascript">
            <![CDATA[
            document.addEventListener("DOMContentLoaded", function () {
                // --- MAPA DE RUTA ---
                var routeContainer = document.getElementById("route-map");
                if (routeContainer && routeContainer.dataset.rutaId) {
                    var rutaId = routeContainer.dataset.rutaId;
                    fetch("/custodia/ruta/" + rutaId + "/coordinates", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ params: {} })
                    }).then(res => res.json()).then(data => {
                        if (data.result && data.result.length) {
                            var points = data.result;
                            var rMap = L.map("route-map").setView([points[0].lat, points[0].lng], 6);
                            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(rMap);
                            var coords = points.map(p => p.lng + "," + p.lat).join(";");
                            fetch("https://router.project-osrm.org/route/v1/driving/" + coords + "?overview=full&geometries=geojson")
                            .then(res => res.json()).then(osrm => {
                                if (osrm.routes && osrm.routes.length) {
                                    var geojson = L.geoJSON(osrm.routes[0].geometry, { style: { color: "#3388ff", weight: 5 } }).addTo(rMap);
                                    rMap.fitBounds(geojson.getBounds());
                                    document.getElementById("route-distance").innerText = (osrm.routes[0].distance / 1000).toFixed(1) + " km";
                                    document.getElementById("route-duration").innerText = Math.round(osrm.routes[0].duration / 3600) + "h " + Math.round((osrm.routes[0].duration % 3600) / 60) + "m";
                                    document.getElementById("route-summary").style.display = "block";
                                }
                            });
                        }
                    });
                }

                // --- MONITOREO EN VIVO ---
                var serviceId = "]]><t t-out='service.id'/><![CDATA[";
                var token = "]]><t t-out='service.access_token'/><![CDATA[";
                var liveMap = L.map('live-map').setView([19.43, -99.13], 6);
                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(liveMap);
                var marker = L.marker([19.43, -99.13]).addTo(liveMap);

                function updateLocation() {
                    // Llamada al endpoint portal_service_tracking de tu portal.py
                    fetch("/mis-servicios/" + serviceId + "/tracking", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ params: { access_token: token } })
                    }).then(res => res.json()).then(data => {
                        // En tu portal.py respondes con json.dumps(data), fetch lo interpreta como data
                        // pero si usas type='http' con json.dumps, data es el objeto directo
                        var res = data.result || data; 
                        if (res.lat && res.lng) {
                            var pos = [res.lat, res.lng];
                            marker.setLatLng(pos);
                            liveMap.panTo(pos);
                        }
                    });
                }
                updateLocation();
                setInterval(updateLocation, 15000);
            });
            ]]>
            </script>
        </t>
    </template>

    <template id="portal_my_home_custodia" inherit_id="portal.portal_my_home" name="Custodia Portal" priority="25">
        <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Servicios de Custodia</t>
                <t t-set="url" t-value="'/mis-servicios'"/>
                <t t-set="placeholder_count" t-value="'services_count'"/>
            </t>
        </xpath>
    </template>

</odoo>
