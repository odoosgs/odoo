<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_service_list" name="Mis Servicios">
        <t t-call="website.layout">
            <div class="container my-4">
                <h2>Mis Servicios de Custodia</h2>
                <a href="/solicitar-servicio" class="btn btn-primary my-3">Solicitar Servicio</a>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Consecutivo</th>
                            <th>Ruta</th>
                            <th>Inicio</th>
                            <th>Nivel</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="services" t-as="s">
                            <tr>
                                <td><t t-esc="s.sequence"/></td>
                                <td><t t-esc="s.ruta_id.name"/></td>
                                <td><t t-esc="s.start_datetime"/></td>
                                <td><t t-esc="s.nivel_seguridad"/></td>
                                <td><t t-esc="s.state"/></td>
                                <td>
                                    <a t-att-href="'/mis-servicios/%s' % s.id" class="btn btn-sm btn-secondary">Ver</a>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="portal_service_detail" name="Detalle del Servicio">
        <t t-call="website.layout">
            <div class="container my-4">
                <h2>Servicio <t t-esc="service.sequence"/></h2>
                <p><b>Cliente:</b> <t t-esc="cliente.display_name"/></p>
                <p><b>Ruta:</b> <t t-esc="service.ruta_id.name"/> (<t t-esc="service.ruta_tipo"/>)</p>
                <p><b>Inicio:</b> <t t-esc="service.start_datetime"/></p>
                <p><b>Nivel:</b> <t t-esc="service.nivel_seguridad"/></p>
                <p><b>Load ID:</b> <t t-esc="service.load_id"/></p>

                <p>
                    <b>Coordenadas:</b>
                    <t t-if="service.start_coords">
                        <a t-att-href="'https://www.google.com/maps?q=' + service.start_coords" target="_blank" class="btn btn-sm btn-outline-primary">Ver Inicio</a>
                    </t>
                    <t t-if="service.end_coords">
                        | <a t-att-href="'https://www.google.com/maps?q=' + service.end_coords" target="_blank" class="btn btn-sm btn-outline-primary">Ver Llegada</a>
                    </t>
                </p>

                <div class="row mt-4">
                    <div class="col-md-6">
                        <h4 class="mt-3">Datos del Carrier</h4>
                        <ul>
                            <li>Tipo de unidad: <t t-esc="service.tipo_unidad"/></li>
                            <li>Placas: <t t-esc="service.placas"/></li>
                            <li>Transporte: <t t-esc="service.transporte"/></li>
                            <li>Operador 1: <t t-esc="service.operador1_nombre"/> — Licencia: <t t-esc="service.operador1_licencia"/></li>
                            <li>Operador 2: <t t-esc="service.operador2_nombre or 'N/A'"/> — Licencia: <t t-esc="service.operador2_licencia or 'N/A'"/></li>
                            <li>Monitoreo 1: <t t-esc="service.tel_monitoreo_1"/></li>
                            <li>Monitoreo 2: <t t-esc="service.tel_monitoreo_2 or 'N/A'"/></li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h4 class="mt-3">Comentarios de Solicitud</h4>
                        <div class="alert alert-light border">
                            <t t-esc="service.comentarios_cliente or 'Sin comentarios adicionales.'"/>
                        </div>
                    </div>
                </div>

                <hr class="my-5"/>

                <div id="service_communication" class="mt-4">
                    <h3 class="mb-4">Chat de Seguimiento e Incidencias</h3>
                    
                    <div id="service_chatter" 
                         t-att-data-res-id="service.id" 
                         t-att-data-res-model="'custodia.service'"
                         class="o_portal_chatter_container">
                        
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="service"/>
                            <t t-set="token" t-value="service.get_portal_url(query_string='?access_token=' + service.access_token) if hasattr(service, 'access_token') else ''"/>
                            <t t-set="hash" t-value="service._sign_token(service.access_token) if hasattr(service, 'access_token') else ''"/>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_service_form" name="Solicitud de Servicio">
        <t t-call="website.layout">
            <div class="container my-4">
                <h2>Solicitar Servicio de Custodia</h2>
                <t t-if="error">
                    <div class="alert alert-danger" role="alert">
                        <strong>Ocurrió un error:</strong> <t t-esc="error"/>
                    </div>
                </t>
                <form action="/solicitar-servicio/submit" method="post" class="row g-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success btn-lg">Registrar Solicitud</button>
                    </div>
                </form>
            </div>
        </t>
    </template>

    <template id="portal_my_home_custodia" inherit_id="portal.portal_my_home" name="Custodia Portal">
        <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Servicios de Custodia</t>
                <t t-set="url" t-value="'/mis-servicios'"/>
                <t t-set="placeholder_count" t-value="'services_count'"/>
            </t>
        </xpath>
    </template>
</odoo>
