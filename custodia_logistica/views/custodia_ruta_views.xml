<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================
     TREE VIEW NODOS
    ========================== -->
    <record id="view_custodia_ruta_nodo_tree" model="ir.ui.view">
        <field name="name">custodia.ruta.nodo.tree</field>
        <field name="model">custodia.ruta.nodo</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="latitude"/>
                <field name="longitude"/>
            </tree>
        </field>
    </record>

    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="view_custodia_ruta_form" model="ir.ui.view">
        <field name="name">custodia.ruta.form</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <form string="Ruta de Custodia">
                <sheet>

                    <!-- TÍTULO -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: CDMX - Nuevo Laredo"/>
                        </h1>
                    </div>

                    <notebook>

                        <!-- =========================
                             TRAYECTO
                        ========================== -->
                        <page string="Trayecto">
                            <group string="Información General">
                                <group>
                                    <field name="tipo"/>
                                    <field name="distancia_km"/>
                                    <field name="tiempo_estimado" widget="float_time"/>
                                </group>
                                <group>
                                    <field name="origen"/>
                                    <field name="destino"/>
                                </group>
                            </group>

                            <group string="Coordenadas">
                                <group>
                                    <field name="origin_latitude"/>
                                    <field name="origin_longitude"/>
                                </group>
                                <group>
                                    <field name="destination_latitude"/>
                                    <field name="destination_longitude"/>
                                </group>
                            </group>
                        </page>

                        <!-- =========================
                             NODOS INTERMEDIOS
                        ========================== -->
                        <page string="Nodos Intermedios">
                            <field name="node_ids" context="{'default_ruta_id': active_id}"
                                   options="{'no_create_edit': False}">
                            </field>
                        </page>


                        <!-- =========================
                             COSTOS
                        ========================== -->
                        <page string="Costos y Peajes">
                            <group string="Detalles Financieros">
                                <field name="tiene_peajes"/>
                                <field name="costo_peaje_estimado"/>
                                <field name="currency_id"/>
                            </group>
                        </page>

                        <!-- =========================
                             DESCRIPCIÓN
                        ========================== -->
                        <page string="Descripción">
                            <field name="descripcion"
                                   placeholder="Detalles adicionales de la ruta..."/>
                        </page>

                        <!-- =========================
                             SEGUIMIENTO / CHATTER
                        ========================== -->
                        <page string="Seguimiento">
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                            </group>

                            <div class="oe_chatter">
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                            </div>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================
         LIST VIEW
    ========================== -->
    <record id="view_custodia_ruta_list" model="ir.ui.view">
        <field name="name">custodia.ruta.list</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <list string="Rutas">
                <field name="name"/>
                <field name="tipo"/>
                <field name="origen"/>
                <field name="destino"/>
                <field name="distancia_km"/>
                <field name="costo_peaje_estimado"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- =========================
         ACTION
    ========================== -->
    <record id="action_custodia_ruta" model="ir.actions.act_window">
        <field name="name">Rutas</field>
        <field name="res_model">custodia.ruta</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

