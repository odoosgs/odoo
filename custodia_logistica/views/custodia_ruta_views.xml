<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Formulario -->
    <record id="view_custodia_ruta_form" model="ir.ui.view">
        <field name="name">custodia.ruta.form</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <form string="Ruta">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: CDMX - Veracruz"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Trayecto">
                            <field name="origen"/>
                            <field name="destino"/>
                            <field name="distancia_km"/>
                            <field name="tiempo_estimado" widget="float_time"/>
                        </group>
                        <group string="Costos y Peajes">
                            <field name="tiene_peajes"/>
                            <field name="costo_peaje_estimado" invisible="not tiene_peajes"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <field name="descripcion" placeholder="Detalles adicionales de la ruta (paradas, riesgos, etc.)..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Lista (List - antes Tree) -->
    <record id="view_custodia_ruta_list" model="ir.ui.view">
        <field name="name">custodia.ruta.list</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <!-- CAMBIO IMPORTANTE v19: Usamos <list> -->
            <list string="Rutas">
                <field name="name"/>
                <field name="origen"/>
                <field name="destino"/>
                <field name="distancia_km"/>
                <field name="costo_peaje_estimado"/>
            </list>
        </field>
    </record>

    <!-- Acción de Ventana -->
    <record id="action_custodia_ruta" model="ir.actions.act_window">
        <field name="name">Rutas</field>
        <field name="res_model">custodia.ruta</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Define la primera ruta de custodia
          </p>
        </field>
    </record>
</odoo>
