    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="view_custodia_ruta_form" model="ir.ui.view">
        <field name="name">custodia.ruta.form</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <form string="Ruta de Custodia">
                <sheet>

                    <!-- TÍTULO -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: CDMX - Nuevo Laredo"/>
                        </h1>
                    </div>

                    <notebook>

                        <!-- =========================
                             TRAYECTO
                        ========================== -->
                        <page string="Trayecto">
                            <group>
                                <group string="Clasificación Operativa">
                                    <field name="ruta_maestra_id" options="{'no_create': True}"/>
                                    <field name="clave_variante"/>
                                    <field name="tipo"/>
                                </group>
                                <group string="Puntos Específicos (Nodos)">
                                    <field name="nodo_origen_id" options="{'no_create': True}"/>
                                    <field name="nodo_destino_id" options="{'no_create': True}"/>
                                    <field name="distancia_km"/>
                                    <field name="tiempo_estimado" widget="float_time"/>
                                </group>
                            </group>

                            <group string="Coordenadas" invisible="1">
                                <group>
                                    <field name="origin_latitude"/>
                                    <field name="origin_longitude"/>
                                </group>
                                <group>
                                    <field name="destination_latitude"/>
                                    <field name="destination_longitude"/>
                                </group>
                            </group>
                        </page>

                        <!-- =========================
                             NODOS INTERMEDIOS
                        ========================== -->
                        
                        <page string="Nodos Intermedios">
                            <field name="node_ids"/>
                        </page>


                        <!-- =========================
                             COSTOS
                        ========================== -->
                        <page string="Costos y Peajes">
                            <group string="Detalles Financieros">
                                <field name="tiene_peajes"/>
                                <field name="costo_peaje_estimado"/>
                                <field name="currency_id"/>
                            </group>
                        </page>

                        <!-- =========================
                             DESCRIPCIÓN
                        ========================== -->
                        <page string="Descripción">
                            <field name="descripcion"
                                   placeholder="Detalles adicionales de la ruta..."/>
                        </page>

                        <!-- =========================
                             SEGUIMIENTO / CHATTER
                        ========================== -->
                        <page string="Seguimiento">
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                            </group>

                            <div class="oe_chatter">
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                            </div>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================
         LIST VIEW
    ========================== -->
    <record id="view_custodia_ruta_list" model="ir.ui.view">
        <field name="name">custodia.ruta.list</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <list string="Rutas">
                <field name="clave_variante"/>
                <field name="ruta_maestra_id"/>
                <field name="nodo_origen_id"/>
                <field name="nodo_destino_id"/>
                <field name="tipo"/>
                <field name="distancia_km"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- =========================
         ACTION
    ========================== -->
    <record id="action_custodia_ruta" model="ir.actions.act_window">
        <field name="name">Rutas</field>
        <field name="res_model">custodia.ruta</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>








