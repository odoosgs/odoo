<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custodia_ruta_form" model="ir.ui.view">
        <field name="name">custodia.ruta.form</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <form string="Ruta de Custodia">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ej: CDMX - Nuevo Laredo"/></h1>
                    </div>
                    <notebook>
                        <page string="Trayecto">
                            <group string="Información del trayecto">
                                <field name="origen"/>
                                <field name="destino"/>
                                <field name="distancia_km"/>
                                <field name="tiempo_estimado" widget="float_time"/>
                                <field name="tipo"/>
                            </group>
                        </page>
                        <page string="Costos y Peajes">
                            <group string="Detalles financieros">
                                <field name="tiene_peajes"/>
                                <field name="costo_peaje_estimado"/>
                                <field name="currency_id"/>
                            </group>
                        </page>
                        <page string="Descripción">
                            <field name="descripcion" placeholder="Detalles adicionales de la ruta..."/>
                        </page>
                        <page string="Seguimiento">
                            <group><field name="active" widget="boolean_toggle"/></group>
                            <div class="oe_chatter">
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_custodia_ruta_list" model="ir.ui.view">
        <field name="name">custodia.ruta.list</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <list string="Rutas">
                <field name="name"/>
                <field name="origen"/>
                <field name="destino"/>
                <field name="distancia_km"/>
                <field name="costo_peaje_estimado"/>
                <field name="tipo"/>
            </list>
        </field>
    </record>

    <record id="action_custodia_ruta" model="ir.actions.act_window">
        <field name="name">Rutas</field>
        <field name="res_model">custodia.ruta</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
