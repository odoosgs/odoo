<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- VISTA FORM RUTA COMERCIAL -->
    <!-- ============================= -->
    <record id="view_custodia_ruta_form" model="ir.ui.view">
        <field name="name">custodia.ruta.form</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <form string="Ruta Comercial de Custodia">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: GDL - Ciudad Juárez"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="tipo"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="tiene_peajes"/>
                            <field name="costo_peaje_estimado" attrs="{'invisible':[('tiene_peajes','=',False)]}"/>
                            <field name="currency_id"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- Variantes -->
                        <page string="Variantes de Ruta">
                            <field name="variante_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="ubicacion_origen_id"/>
                                    <field name="ubicacion_destino_id"/>
                                    <field name="distancia_km"/>
                                    <field name="tiempo_estimado"/>
                                    <field name="activa"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Descripción -->
                        <page string="Descripción">
                            <field name="descripcion"
                                   placeholder="Detalles adicionales de la ruta comercial..."/>
                        </page>

                        <!-- Chatter -->
                        <page string="Seguimiento">
                            <div class="oe_chatter">
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                            </div>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <!-- ============================= -->
    <!-- VISTA LISTA RUTA COMERCIAL -->
    <!-- ============================= -->
    <record id="view_custodia_ruta_list" model="ir.ui.view">
        <field name="name">custodia.ruta.list</field>
        <field name="model">custodia.ruta</field>
        <field name="arch" type="xml">
            <tree string="Rutas Comerciales">
                <field name="name"/>
                <field name="tipo"/>
                <field name="tiene_peajes"/>
                <field name="costo_peaje_estimado"/>
                <field name="active"/>
            </tree>
        </field>
    </record>


    <!-- ============================= -->
    <!-- ACCIÓN -->
    <!-- ============================= -->
    <record id="action_custodia_ruta" model="ir.actions.act_window">
        <field name="name">Rutas Comerciales</field>
        <field name="res_model">custodia.ruta</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
