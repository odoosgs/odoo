<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custodia_punto_operativo_tree" model="ir.ui.view">
        <field name="name">custodia.punto.operativo.tree</field>
        <field name="model">custodia.punto.operativo</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="latitude"/>
                <field name="longitude"/>
            </list>
        </field>
    </record>

    <record id="view_custodia_ruta_maestra_tree" model="ir.ui.view">
        <field name="name">custodia.ruta.maestra.tree</field>
        <field name="model">custodia.ruta.maestra</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_custodia_punto_operativo" model="ir.actions.act_window">
        <field name="name">Nodos (Bodegas)</field>
        <field name="res_model">custodia.punto.operativo</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_custodia_ruta_maestra" model="ir.actions.act_window">
        <field name="name">Rutas Maestras</field>
        <field name="res_model">custodia.ruta.maestra</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
