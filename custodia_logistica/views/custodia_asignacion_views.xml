<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vista lista del hijo -->
  <record id="view_custodia_asignacion_tree" model="ir.ui.view">
    <field name="name">custodia.asignacion.tree</field>
    <field name="model">custodia.asignacion</field>
    <field name="arch" type="xml">
      <tree editable="bottom">
        <field name="service_id"/>
        <field name="notes"/>
        <field name="employee_ids"/>
        <field name="vehicle_ids"/>
        <field name="candado_ids"/>
        <field name="radio_ids"/>
      </tree>
    </field>
  </record>

  <!-- Vista formulario del hijo -->
  <record id="view_custodia_asignacion_form" model="ir.ui.view">
    <field name="name">custodia.asignacion.form</field>
    <field name="model">custodia.asignacion</field>
    <field name="arch" type="xml">
      <form string="Asignación de Custodia">
        <sheet>
          <group>
            <field name="service_id" readonly="1"/>
            <field name="notes"/>
          </group>
          <group>
            <field name="employee_ids"/>
            <field name="vehicle_ids"/>
          </group>
          <group>
            <field name="candado_ids"/>
            <field name="radio_ids"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Acción y menú para asignaciones -->
  <record id="action_custodia_asignacion" model="ir.actions.act_window">
    <field name="name">Asignaciones de Custodia</field>
    <field name="res_model">custodia.asignacion</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_custodia_asignacion"
            name="Asignaciones"
            parent="menu_custodia_root"
            action="action_custodia_asignacion"/>
</odoo>
