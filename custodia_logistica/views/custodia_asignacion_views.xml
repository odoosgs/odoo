<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_custodia_asignacion_tree" model="ir.ui.view">
    <field name="name">custodia.asignacion.tree</field>
    <field name="model">custodia.asignacion</field>
    <field name="arch" type="xml">
      <tree editable="bottom">
        <field name="service_id"/>
        <field name="notes"/>
        <field name="employee_ids"/>
        <field name="vehicle_ids"/>
        <field name="candado_ids"/>
        <field name="radio_ids"/>
      </tree>
    </field>
  </record>

  <record id="view_custodia_asignacion_form" model="ir.ui.view">
    <field name="name">custodia.asignacion.form</field>
    <field name="model">custodia.asignacion</field>
    <field name="arch" type="xml">
      <form string="Asignación de Custodia">
        <sheet>
          <group>
            <field name="service_id" readonly="1"/>
            <field name="notes"/>
