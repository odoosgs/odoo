<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vista Formulario -->
  <record id="view_custodia_service_form" model="ir.ui.view">
    <field name="name">custodia.service.form</field>
    <field name="model">custodia.service</field>
    <field name="arch" type="xml">
      <form string="Servicio de Custodia">
        <header>
          <button name="action_asignar" type="object" string="Asignar" class="oe_highlight"/>
          <button name="action_aprobar" type="object" string="Aprobar" class="oe_highlight"/>
          <button name="action_iniciar" type="object" string="Iniciar" class="oe_highlight"/>
          <button name="action_finalizar" type="object" string="Finalizar" class="oe_highlight"/>
          <button name="action_cancelar" type="object" string="Cancelar"/>
          <button name="action_generar_asignaciones_por_nivel" type="object" string="Generar Asignaciones" class="oe_highlight"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="solicitado,asignado,aprobado,en_ejecucion,finalizado,cancelado"/>
        </header>

        <sheet>
          <group string="Datos del cliente">
            <field name="partner_id"/>
            <field name="contact_id"/>
          </group>

          <group string="Servicio">
            <field name="carrier_id"/>
            <field name="ruta_id"/>
            <field name="ruta_tipo" readonly="1"/>
            <field name="nivel_seguridad"/>
            <field name="start_datetime"/>
            <field name="load_id"/>
          </group>

          <notebook>
            <!-- Asignaciones -->
            <page string="Asignaciones">
              <group>
                <field name="planner_id"/>
              </group>
              <!-- Bloque correctamente anidado -->
              <field name="asignacion_ids">
                <tree editable="bottom">
                  <field name="notes"/>
                  <field name="employee_ids"/>
                  <field name="vehicle_ids"/>
                  <field name="candado_ids"/>
                  <field name="radio_ids"/>
                </tree>
                <form>
                  <sheet>
                    <group>
                      <field name="notes"/>
                      <field name="employee_ids"/>
                      <field name="vehicle_ids"/>
                      <field name="candado_ids"/>
                      <field name="radio_ids"/>
                    </group>
                  </sheet>
                </form>
              </field>
            </page>

            <!-- Compras -->
            <page string="Compras">
              <field name="purchase_ids">
                <tree>
                  <field name="name"/>
                  <field name="partner_id"/>
                  <field name="amount_total"/>
                  <field name="state"/>
                </tree>
              </field>
            </page>

            <!-- Facturación -->
            <page string="Facturación">
              <field name="account_move_ids">
                <tree>
                  <field name="name"/>
                  <field name="invoice_date"/>
                  <field name="partner_id"/>
                  <field name="amount_total"/>
                  <field name="payment_state"/>
                  <field name="state"/>
                </tree>
              </field>
            </page>

            <!-- Planeación -->
            <page string="Planeación">
              <field name="planning_slot_ids">
                <tree>
                  <field name="name"/>
                  <field name="start_datetime"/>
                  <field name="end_datetime"/>
                  <field name="resource_id"/>
                  <field name="state"/>
                </tree>
              </field>
            </page>

            <!-- Seguimiento -->
            <page string="Seguimiento">
              <div class="oe_chatter">
                <field name="message_follower_ids"/>
                <field name="activity_ids"/>
                <field name="message_ids"/>
              </div>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Vista Lista -->
  <record id="view_custodia_service_list" model="ir.ui.view">
    <field name="name">custodia.service.list</field>
    <field name="model">custodia.service</field>
    <field name="arch" type="xml">
      <list string="Servicios de Custodia">
        <field name="sequence"/>
        <field name="partner_id"/>
        <field name="contact_id"/>
        <field name="carrier_id"/>
        <field name="ruta_id"/>
        <field name="start_datetime"/>
        <field name="nivel_seguridad"/>
        <field name="load_id"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <!-- Acción -->
  <record id="action_custodia_service" model="ir.actions.act_window">
    <field name="name">Servicios</field>
    <field name="res_model">custodia.service</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
