<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_custodia_service_form" model="ir.ui.view">
    <field name="name">custodia.service.form</field>
    <field name="model">custodia.service</field>
    <field name="arch" type="xml">
      <form string="Servicio de Custodia">
        <sheet>
          <!-- Datos principales del servicio -->
          <group>
            <field name="sequence"/>
            <field name="partner_id"/>
            <field name="contact_id"/>
            <field name="carrier_id"/>
            <field name="ruta_id"/>
            <field name="ruta_tipo"/>
            <field name="nivel_seguridad"/>
            <field name="start_datetime"/>
            <field name="load_id"/>
          </group>

          <notebook>
            <!-- Pestaña de asignaciones -->
            <page string="Asignaciones">
              <!-- Este bloque apunta al modelo hijo custodia.asignacion -->
              <field name="asignacion_ids">
                <tree editable="bottom">
                  <field name="notes"/>
                  <field name="employee_ids"/>
                  <field name="vehicle_ids"/>
                  <field name="candado_ids"/>
                  <field name="radio_ids"/>
                </tree>
                <form>
                  <sheet>
                    <group>
                      <field name="notes"/>
                      <field name="employee_ids"/>
                      <field name="vehicle_ids"/>
                      <field name="candado_ids"/>
                      <field name="radio_ids"/>
                    </group>
                  </sheet>
                </form>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
