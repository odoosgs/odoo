<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custodia_service_list" model="ir.ui.view">
        <field name="name">custodia.service.list</field>
        <field name="model">custodia.service</field>
        <field name="arch" type="xml">
            <list string="Servicios" decoration-info="state == 'solicitado'" decoration-success="state == 'aprobado'">
                <field name="sequence"/>
                <field name="start_datetime"/>
                <field name="partner_id"/>
                <field name="ruta_maestra_id"/>
                <field name="load_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_custodia_service_calendar" model="ir.ui.view">
        <field name="name">custodia.service.calendar</field>
        <field name="model">custodia.service</field>
        <field name="arch" type="xml">
            <calendar string="Planeación" date_start="start_datetime" color="state" mode="month">
                <field name="partner_id"/>
                <field name="ruta_id"/>
                <field name="load_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_custodia_service_form" model="ir.ui.view">
        <field name="name">custodia.service.form</field>
        <field name="model">custodia.service</field>
        <field name="arch" type="xml">
            <form string="Servicio de Custodia">
                <header>
                    <button name="action_aprobar" type="object" string="Confirmar Servicio" class="btn-primary" invisible="state != 'solicitado'"/>
                    <button name="action_asignar" type="object" string="Asignar" class="btn-secondary" invisible="state != 'aprobado'"/>
                    <button name="action_cancelar" type="object" string="Cancelar" class="btn-danger" invisible="state == 'finalizado'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="sequence"/></h1>
                    </div>
                    <group>
                        <group string="Información del Cliente">
                            <field name="partner_id"/>
                            <field name="contact_id" domain="[('parent_id','=',partner_id)]"/>
                            <field name="load_id"/>
                        </group>
                        <group string="Ubicación y Ruta">
                            <field name="ruta_maestra_id"/>
                            <field name="nodo_origen_id" domain="[('ruta_maestra_id','=',ruta_maestra_id)]"/>
                            <field name="nodo_destino_id" domain="[('ruta_maestra_id','=',ruta_maestra_id)]"/>
                            <field name="ruta_id" readonly="1" force_save="1"/>
                        </group>
                        <group string="Programación">
                            <field name="start_datetime"/>
                            <field name="nivel_seguridad"/>
                        </group>
                        <group string="Datos del Vehículo">
                            <field name="carrier_id"/>
                            <field name="transporte"/>
                            <field name="placas"/>
                            <field name="tipo_unidad"/>
                            <field name="operador1_nombre"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Asignaciones" name="asignaciones">
                            <field name="asignacion_ids"/>
                        </page>
                        <page string="Comentarios" name="comentarios">
                            <field name="comentarios_cliente"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_custodia_service" model="ir.actions.act_window">
        <field name="name">Servicios de Custodia</field>
        <field name="res_model">custodia.service</field>
        <field name="view_mode">list,calendar,form,kanban</field>
    </record>

    <menuitem id="menu_custodia_root" name="Custodia de Valores" sequence="10"/>
    <menuitem id="menu_custodia_service" name="Servicios" parent="menu_custodia_root" action="action_custodia_service" sequence="10"/>
</odoo>
