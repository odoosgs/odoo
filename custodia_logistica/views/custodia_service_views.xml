<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_custodia_service_form" model="ir.ui.view">
    <field name="name">custodia.service.form</field>
    <field name="model">custodia.service</field>
    <field name="arch" type="xml">
      <form string="Servicio de Custodia">
        <header>
          <button name="action_convert_to_service" type="object" string="Convertir a servicio" class="btn-primary"
                  invisible="request_type != 'alerta'"/>
          <button name="action_aprobar" type="object" string="Aprobar" class="btn-primary"
                  invisible="state != 'solicitado'"/>
          <button name="action_asignar" type="object" string="Asignar" class="btn-secondary"
                  invisible="state != 'aprobado'"/>
          <button name="action_ejecutar" type="object" string="Ejecutar" class="btn-secondary"
                  invisible="state != 'asignado'"/>
          <button name="action_finalizar" type="object" string="Finalizar" class="btn-success"
                  invisible="state != 'en_ejecucion'"/>
          <button name="action_cancelar" type="object" string="Cancelar" class="btn-danger"
                  invisible="state in ('finalizado', 'cancelado')"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="alerta,solicitado,aprobado,asignado,en_ejecucion,finalizado,cancelado"/>
        </header>
        <sheet>
          <group>
            <field name="name" readonly="1"/>
            <field name="request_type"/>
            <field name="partner_id"/>
            <field name="contact_id"/>
            <field name="start_datetime"/>
            <field name="carrier_id"/>
            <field name="ruta_id"/>
            <field name="nivel_seguridad"/>
            <field name="load_id"/>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="view_custodia_service_tree" model="ir.ui.view">
    <field name="name">custodia.service.tree</field>
    <field name="model">custodia.service</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="request_type"/>
        <field name="partner_id"/>
        <field name="contact_id"/>
        <field name="start_datetime"/>
        <field name="carrier_id"/>
        <field name="ruta_id"/>
        <field name="load_id"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="view_custodia_service_calendar" model="ir.ui.view">
    <field name="name">custodia.service.calendar</field>
    <field name="model">custodia.service</field>
    <field name="arch" type="xml">
      <calendar string="Planeación de Custodias" date_start="start_datetime" color="calendar_color" event_open_popup="true">
        <field name="name"/>
        <field name="request_type"/>
        <field name="partner_id"/>
        <field name="contact_id"/>
        <field name="carrier_id"/>
        <field name="ruta_id"/>
        <field name="load_id"/>
        <field name="state"/>
      </calendar>
    </field>
  </record>

  <record id="action_custodia_service" model="ir.actions.act_window">
    <field name="name">Servicios y Alertas de Custodia</field>
    <field name="res_model">custodia.service</field>
    <field name="view_mode">list,calendar,form</field>
  </record>
</odoo>
