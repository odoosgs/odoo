<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custodia_carrier_form" model="ir.ui.view">
        <field name="name">custodia.carrier.form</field>
        <field name="model">custodia.carrier</field>
        <field name="arch" type="xml">
            <form string="Carrier">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del Carrier"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="rfc"/>
                            <field name="tipo_servicio"/>
                        </group>
                        <group>
                            <field name="telefono"/>
                            <field name="email"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas">
                            <field name="notas"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_custodia_carrier_tree" model="ir.ui.view">
        <field name="name">custodia.carrier.tree</field>
        <field name="model">custodia.carrier</field>
        <field name="arch" type="xml">
            <tree string="Carriers">
                <field name="name"/>
                <field name="rfc"/>
                <field name="tipo_servicio"/>
                <field name="telefono"/>
                <field name="email"/>
            </tree>
        </field>
    </record>

    <record id="action_custodia_carrier" model="ir.actions.act_window">
        <field name="name">Carriers</field>
        <field name="res_model">custodia.carrier</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>