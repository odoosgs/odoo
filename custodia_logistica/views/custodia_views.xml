<record id="view_custodia_form" model="ir.ui.view">
    <field name="name">custodia.orden.form</field>
    <field name="model">custodia.orden</field>
    <field name="arch" type="xml">
        <form string="Plantilla de Custodia">
            <sheet>
                <div class="oe_title">
                    <h1><field name="name"/></h1>
                </div>
                <group>
                    <group string="Información de Transporte">
                        <field name="linea_transporte"/>
                        <field name="nombre_operador"/>
                        <field name="placas_tractor"/>
                        <field name="placas_caja"/>
                        <field name="eco"/>
                    </group>
                    <group string="Datos de la Unidad / Ruta">
                        <field name="custodio_cargo"/>
                        <field name="marca_unidad"/>
                        <field name="placas_unidad"/>
                        <field name="origen"/>
                        <field name="destino"/>
                        <field name="cliente_id"/>
                    </group>
                </group>

                <div style="background-color: #FF0000; color: white; text-align: center; font-weight: bold; padding: 5px; margin-bottom: 10px;">
                    NÚMERO DE EMERGENCIA 088 O 911
                </div>

                <notebook>
                    <page string="Bitácora de Seguimiento" name="bitacora">
                        <field name="bitacora_ids">
                            <tree editable="bottom">
                                <field name="fecha"/>
                                <field name="hora" widget="float_time"/>
                                <field name="gps"/>
                                <field name="tipo_reporte"/>
                                <field name="ubicacion"/>
                                <field name="comentarios"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>
