<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_service_detail" name="Detalle Servicio Custodia">

        <t t-call="portal.portal_layout">
            <div class="container mt-4">

                <h3>
                    Servicio
                    <t t-esc="service.name"/>
                </h3>

                <div class="row mt-3">
                    <div class="col-md-6">
                        <strong>Fecha programada:</strong>
                        <span t-field="service.start_datetime"/>
                    </div>

                    <div class="col-md-6">
                        <strong>Estado:</strong>
                        <t t-esc="service.state"/>
                    </div>
                </div>

                <div class="mt-4">
                    <div id="route_map"
                         t-att-data-ruta-id="service.ruta_id.id"
                         style="height:500px;">
                    </div>

                    <div id="route_info" class="mt-2"></div>
                </div>

            </div>
        </t>

    </template>

</odoo>
